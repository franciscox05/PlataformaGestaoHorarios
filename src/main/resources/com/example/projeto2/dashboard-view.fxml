<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.DashboardController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label fx:id="lblBemVindo" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Bem-vindo ao Dashboard!" />
    <Label text="Os teus próximos turnos:" />

    <TableView fx:id="tabelaTurnos" prefHeight="400.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colData" prefWidth="120.0" text="Data" />
            <TableColumn fx:id="colHorario" prefWidth="150.0" text="Horário" />
            <TableColumn fx:id="colLoja" prefWidth="250.0" text="Loja" />
            <TableColumn fx:id="colEstado" prefWidth="150.0" text="Estado" />
        </columns>
    </TableView>
</VBox>