<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" styleClass="modal-card"
      stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.projeto2.Controller.AlterarPasswordController">

    <padding>
        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
    </padding>

    <!-- Cabeçalho -->
    <VBox spacing="4.0">
                <Label styleClass="titulo-dashboard, modal-titulo" text="Alterar Password" />
        <Label styleClass="texto-ajuda"
               text="Confirma a password atual e define a nova password de acesso a esta conta."
               wrapText="true" />
    </VBox>

    <!-- Password atual -->
    <VBox spacing="6.0">
        <Label styleClass="campo-titulo" text="Password atual" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <StackPane HBox.hgrow="ALWAYS">
                <PasswordField fx:id="txtPasswordAtual" maxWidth="Infinity"
                               promptText="Insere a tua password atual" styleClass="campo-input" />
                <TextField fx:id="txtPasswordAtualVisivel" maxWidth="Infinity"
                           styleClass="campo-input" visible="false" />
            </StackPane>
            <ToggleButton fx:id="btnVerPassAtual" focusTraversable="false" styleClass="botao-iconico">
                <graphic>
                    <ImageView fx:id="imgPassAtual" fitHeight="20.0" fitWidth="20.0"
                               pickOnBounds="true" preserveRatio="true">
                        <Image url="@../imagens/login/olho-aberto.png" />
                    </ImageView>
                </graphic>
            </ToggleButton>
        </HBox>
    </VBox>

    <!-- Nova password -->
    <VBox spacing="6.0">
        <Label styleClass="campo-titulo" text="Nova password" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <StackPane HBox.hgrow="ALWAYS">
                <PasswordField fx:id="txtNovaPassword" maxWidth="Infinity"
                               promptText="Mínimo 6 caracteres" styleClass="campo-input" />
                <TextField fx:id="txtNovaPasswordVisivel" maxWidth="Infinity"
                           styleClass="campo-input" visible="false" />
            </StackPane>
            <ToggleButton fx:id="btnVerNovaPass" focusTraversable="false" styleClass="botao-iconico">
                <graphic>
                    <ImageView fx:id="imgNovaPass" fitHeight="20.0" fitWidth="20.0"
                               pickOnBounds="true" preserveRatio="true">
                        <Image url="@../imagens/login/olho-aberto.png" />
                    </ImageView>
                </graphic>
            </ToggleButton>
        </HBox>
    </VBox>

    <!-- Confirmar password -->
    <VBox spacing="6.0">
        <Label styleClass="campo-titulo" text="Confirmar nova password" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <StackPane HBox.hgrow="ALWAYS">
                <PasswordField fx:id="txtConfirmarPassword" maxWidth="Infinity"
                               promptText="Repete a nova password" styleClass="campo-input" />
                <TextField fx:id="txtConfirmarPasswordVisivel" maxWidth="Infinity"
                           styleClass="campo-input" visible="false" />
            </StackPane>
            <ToggleButton fx:id="btnVerConfirmarPass" focusTraversable="false" styleClass="botao-iconico">
                <graphic>
                    <ImageView fx:id="imgConfirmarPass" fitHeight="20.0" fitWidth="20.0"
                               pickOnBounds="true" preserveRatio="true">
                        <Image url="@../imagens/login/olho-aberto.png" />
                    </ImageView>
                </graphic>
            </ToggleButton>
        </HBox>
    </VBox>

    <CheckBox fx:id="chkMostrarTodas" focusTraversable="false"
              styleClass="texto-ajuda" text="Mostrar todas as passwords" />

    <Label fx:id="lblErro" managed="false"
                       styleClass="mensagem-feedback, mensagem-erro"
           text="Não foi possível guardar." textAlignment="CENTER"
           visible="false" wrapText="true" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Button cancelButton="true" onAction="#onCancelarClick"
                styleClass="botao-secundario" text="Cancelar" />
        <Button defaultButton="true" onAction="#onGuardarClick"
                styleClass="botao-acao" text="Guardar" />
    </HBox>

</VBox>
