<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="mainContainer"
            styleClass="page-shell"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-header">
            <padding>
                <Insets top="15.0" right="30.0" bottom="15.0" left="30.0" />
            </padding>

            <VBox spacing="2.0" minWidth="150.0">
                <Label styleClass="top-header-brand" text="PORTAL DE GEST&#195;O" />
                <HBox alignment="CENTER_LEFT" spacing="7.0">
                    <Label styleClass="top-breadcrumb-muted" text="Home" />
                    <Label styleClass="top-breadcrumb-muted" text="&#8250;" />
                    <Label fx:id="lblTopPageTitle"
                           styleClass="top-header-page-title"
                           text="Painel" />
                </HBox>
            </VBox>

            <HBox spacing="2.0" styleClass="top-nav-group">
                <Button fx:id="btnTopoVisaoGeral"
                        onAction="#onTopVisaoGeralClick"
                        styleClass="top-nav-button, top-nav-button-ativo"
                        text="Vis&#227;o Geral" />
                <Button fx:id="btnTopoPedidos"
                        onAction="#onTopPedidosClick"
                        styleClass="top-nav-button"
                        text="Pedidos" />
                <Button fx:id="btnTopoPerfil"
                        onAction="#onTopPerfilClick"
                        styleClass="top-nav-button"
                        text="Perfil" />
            </HBox>

            <HBox fx:id="boxPesquisa"
                  alignment="CENTER_LEFT"
                  prefWidth="380.0"
                  styleClass="pesquisa-shell">
                <TextField fx:id="txtPesquisa"
                           promptText="Pesquisar m&#243;dulos e a&#231;&#245;es"
                           styleClass="pesquisa-input"
                           HBox.hgrow="ALWAYS" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#onPedirFolgaClick"
                    styleClass="top-primary-action"
                    text="Novo Pedido" />

            <Region prefWidth="6.0" />

            <VBox alignment="CENTER_RIGHT" spacing="1.0">
                <Label fx:id="lblTopUserName" styleClass="top-user-name" text="Staff" />
                <Label fx:id="lblTopUserRole" styleClass="top-user-role" text="Portal interno" />
            </VBox>

            <Button onAction="#onLogoutClick"
                    styleClass="botao-logout"
                    text="Terminar sess&#227;o" />
        </HBox>
    </top>

    <left>
        <BorderPane styleClass="sidebar">

            <top>
                <VBox>
                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sidebar-brand">
                        <StackPane styleClass="sidebar-brand-icon">
                            <Label styleClass="sidebar-brand-icon-text" text="L" />
                        </StackPane>
                        <VBox spacing="1.0">
                            <Label styleClass="sidebar-titulo" text="Levi's Staff" />
                            <Label styleClass="sidebar-subtitulo" text="WORKSPACE EDITORIAL" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          onMouseClicked="#onTopPerfilClick"
                          styleClass="sidebar-user-row, sidebar-user-row-clickable">
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sidebar-user-card" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="sidebar-avatar">
                                <Label fx:id="lblAvatarInicial"
                                       styleClass="sidebar-avatar-text"
                                       text="L" />
                            </StackPane>
                            <VBox spacing="1.0">
                                <Label fx:id="lblUtilizadorSidebar"
                                       styleClass="sidebar-user-greeting"
                                       text="Ol&#225;, Staff!" />
                                <Label fx:id="lblCargoSidebar" styleClass="sidebar-subtitulo" text="VER PERFIL" />
                            </VBox>
                        </HBox>
                    </HBox>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            styleClass="sidebar-scroll"
                            vbarPolicy="AS_NEEDED">
                    <VBox styleClass="sidebar-menu">

                        <Label styleClass="sidebar-section-label" text="PRINCIPAL" />

                        <Button fx:id="btnDashboard"
                                onAction="#onDashboardHomeClick"
                                maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn, sidebar-btn-ativo"
                                text="Painel">
                            <graphic><FontIcon iconLiteral="mdi2v-view-dashboard" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <StackPane maxWidth="Infinity">
                            <Button fx:id="btnFolgas"
                                    onAction="#onPedirFolgaClick"
                                    maxWidth="Infinity"
                                    graphicTextGap="12.0"
                                    styleClass="sidebar-btn"
                                    text="Folgas"
                                    StackPane.alignment="CENTER">
                                <graphic><FontIcon iconLiteral="mdi2c-calendar-remove" iconSize="18" styleClass="sidebar-icon" /></graphic>
                            </Button>
                            <Label fx:id="badgeFolgas"
                                   styleClass="sidebar-notif-badge"
                                   visible="false"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets top="4.0" right="6.0"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <StackPane maxWidth="Infinity">
                            <Button fx:id="btnPermutas"
                                    onAction="#onTrocarTurnoClick"
                                    maxWidth="Infinity"
                                    graphicTextGap="12.0"
                                    styleClass="sidebar-btn"
                                    text="Permutas"
                                    StackPane.alignment="CENTER">
                                <graphic><FontIcon iconLiteral="mdi2s-swap-horizontal" iconSize="18" styleClass="sidebar-icon" /></graphic>
                            </Button>
                            <Label fx:id="badgePermutas"
                                   styleClass="sidebar-notif-badge"
                                   visible="false"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets top="4.0" right="6.0"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <Label fx:id="lblSecaoGestao"
                               managed="false" visible="false"
                               styleClass="sidebar-section-label" text="GEST&#195;O" />

                        <StackPane managed="false" maxWidth="Infinity" visible="false"
                                   fx:id="stackHorarios">
                            <Button fx:id="btnHorarios"
                                    onAction="#onHorariosClick"
                                    maxWidth="Infinity"
                                    graphicTextGap="12.0"
                                    styleClass="sidebar-btn"
                                    text="Hor&#225;rios"
                                    StackPane.alignment="CENTER">
                                <graphic><FontIcon iconLiteral="mdi2c-calendar-month" iconSize="18" styleClass="sidebar-icon" /></graphic>
                            </Button>
                            <Label fx:id="badgeHorarios"
                                   styleClass="sidebar-notif-badge"
                                   visible="false"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets top="4.0" right="6.0"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <Button fx:id="btnGestaoLoja"
                                onAction="#onGestaoLojaClick"
                                managed="false" maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn"
                                text="Loja e Regras"
                                visible="false">
                            <graphic><FontIcon iconLiteral="mdi2s-store" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <Button fx:id="btnGestaoFuncionarios"
                                onAction="#onGestaoFuncionariosClick"
                                managed="false" maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn"
                                text="Funcion&#225;rios"
                                visible="false">
                            <graphic><FontIcon iconLiteral="mdi2a-account-group" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <StackPane managed="false" maxWidth="Infinity" visible="false"
                                   fx:id="stackPainelGerente">
                            <Button fx:id="btnPainelGerente"
                                    onAction="#onPainelGerentePedidosClick"
                                    maxWidth="Infinity"
                                    graphicTextGap="12.0"
                                    styleClass="sidebar-btn"
                                    text="Pedidos"
                                    StackPane.alignment="CENTER">
                                <graphic><FontIcon iconLiteral="mdi2c-clipboard-list" iconSize="18" styleClass="sidebar-icon" /></graphic>
                            </Button>
                            <Label fx:id="badgePainelGerente"
                                   styleClass="sidebar-notif-badge"
                                   visible="false"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets top="4.0" right="6.0"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <Button fx:id="btnRelatorios"
                                onAction="#onRelatoriosHorasClick"
                                managed="false" maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn"
                                text="Relat&#243;rios"
                                visible="false">
                            <graphic><FontIcon iconLiteral="mdi2c-chart-bar" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <Button fx:id="btnAuditoria"
                                onAction="#onPainelAuditoriaClick"
                                managed="false" maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn"
                                text="Auditoria"
                                visible="false">
                            <graphic><FontIcon iconLiteral="mdi2s-shield-check" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <Label styleClass="sidebar-section-label" text="CONTA" />

                        <Button fx:id="btnPerfil"
                                onAction="#onPerfilClick"
                                maxWidth="Infinity"
                                graphicTextGap="12.0"
                                styleClass="sidebar-btn"
                                text="Perfil">
                            <graphic><FontIcon iconLiteral="mdi2a-account-circle" iconSize="18" styleClass="sidebar-icon" /></graphic>
                        </Button>

                        <StackPane maxWidth="Infinity">
                            <Button fx:id="btnPreferencias"
                                    onAction="#onPreferenciasClick"
                                    maxWidth="Infinity"
                                    graphicTextGap="12.0"
                                    styleClass="sidebar-btn"
                                    text="Prefer&#234;ncias"
                                    StackPane.alignment="CENTER">
                                <graphic><FontIcon iconLiteral="mdi2s-star-outline" iconSize="18" styleClass="sidebar-icon" /></graphic>
                            </Button>
                            <Label fx:id="badgePreferencias"
                                   styleClass="sidebar-notif-badge"
                                   visible="false"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets top="4.0" right="6.0"/></StackPane.margin>
                            </Label>
                        </StackPane>

                    </VBox>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="10.0" styleClass="sidebar-footer">
                    <Label styleClass="sidebar-footer-title" text="FLUXO EDITORIAL" />
                    <Label styleClass="sidebar-footer-copy"
                           text="Centraliza hor&#225;rios, equipa, pedidos e auditoria."
                           wrapText="true" />
                    <Button fx:id="btnFecharAplicacao"
                            onAction="#onFecharAplicacaoClick"
                            maxWidth="Infinity"
                            styleClass="botao-fechar-app"
                            text="Fechar aplica&#231;&#227;o" />
                </VBox>
            </bottom>

        </BorderPane>
    </left>

</BorderPane>
