<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer"
            styleClass="page-shell"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="top-header">
            <padding>
                <Insets top="14.0" right="28.0" bottom="14.0" left="28.0" />
            </padding>

            <VBox spacing="2.0" minWidth="142.0">
                <Label styleClass="top-header-brand" text="Portal de Gestão" />
                <HBox alignment="CENTER_LEFT" spacing="7.0">
                    <Label styleClass="top-breadcrumb-muted" text="Home" />
                    <Label styleClass="top-breadcrumb-muted" text="›" />
                    <Label fx:id="lblTopPageTitle"
                           styleClass="top-header-page-title"
                           text="Painel" />
                </HBox>
            </VBox>

            <HBox spacing="6.0" styleClass="top-nav-group">
                <Button fx:id="btnTopoVisaoGeral"
                        onAction="#onTopVisaoGeralClick"
                        styleClass="top-nav-button, top-nav-button-ativo"
                        text="Vis&#227;o Geral" />
                <Button fx:id="btnTopoPedidos"
                        onAction="#onTopPedidosClick"
                        styleClass="top-nav-button"
                        text="Pedidos" />
                <Button fx:id="btnTopoPerfil"
                        onAction="#onTopPerfilClick"
                        styleClass="top-nav-button"
                        text="Perfil" />
            </HBox>

            <HBox fx:id="boxPesquisa"
                  alignment="CENTER_LEFT"
                  prefWidth="430.0"
                  styleClass="pesquisa-shell">
                <TextField fx:id="txtPesquisa"
                           promptText="Pesquisar módulos e ações"
                           styleClass="pesquisa-input"
                           HBox.hgrow="ALWAYS" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button styleClass="top-icon-btn" text="&#128276;" />
            <Button styleClass="top-icon-btn" text="?" />
            <Button onAction="#onPedirFolgaClick"
                    styleClass="top-primary-action"
                    text="Novo Pedido" />
            <Region prefWidth="10.0" />
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblTopUserName" styleClass="top-user-name" text="Staff" />
                <Label fx:id="lblTopUserRole" styleClass="top-user-role" text="Portal interno" />
            </VBox>

            <Button onAction="#onLogoutClick"
                    styleClass="botao-logout"
                    text="Terminar sess&#227;o" />
        </HBox>
    </top>

    <left>
        <BorderPane styleClass="sidebar">

            <top>
                <VBox>
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-brand">
                        <StackPane styleClass="sidebar-brand-icon">
                            <Label styleClass="sidebar-brand-icon-text" text="_" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label styleClass="sidebar-titulo" text="Levi's Staff" />
                            <Label styleClass="sidebar-subtitulo" text="Portal de Gest&#227;o" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          onMouseClicked="#onTopPerfilClick"
                          spacing="12.0"
                          styleClass="sidebar-user-row, sidebar-user-row-clickable">
                        <StackPane styleClass="sidebar-avatar">
                            <Label fx:id="lblAvatarInicial"
                                   styleClass="sidebar-avatar-text"
                                   text="L" />
                        </StackPane>
                        <Label fx:id="lblUtilizadorSidebar"
                               styleClass="sidebar-user-greeting"
                               text="Ol&#225;, Staff!" />
                    </HBox>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            styleClass="sidebar-scroll"
                            vbarPolicy="AS_NEEDED">
                    <VBox spacing="2.0" styleClass="sidebar-menu">
                        <Button fx:id="btnDashboard"
                                onAction="#onDashboardHomeClick"
                                maxWidth="Infinity"
                                styleClass="sidebar-btn, sidebar-btn-ativo"
                                text="▦   Painel" />

                        <Button fx:id="btnGestaoLoja"
                                onAction="#onGestaoLojaClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="▤   Loja e Regras"
                                visible="false" />
                        <Button fx:id="btnGestaoFuncionarios"
                                onAction="#onGestaoFuncionariosClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="👥   Funcion&#225;rios"
                                visible="false" />
                        <Button fx:id="btnHorarios"
                                onAction="#onHorariosClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="◷   Hor&#225;rios"
                                visible="false" />
                        <Button fx:id="btnPainelGerente"
                                onAction="#onPainelGerentePedidosClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="🛒   Pedidos"
                                visible="false" />
                        <Button fx:id="btnAuditoria"
                                onAction="#onPainelAuditoriaClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="🛡   Auditoria"
                                visible="false" />

                        <Button fx:id="btnFolgas"
                                onAction="#onPedirFolgaClick"
                                maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="☕   Folgas" />
                        <Button fx:id="btnPermutas"
                                onAction="#onTrocarTurnoClick"
                                maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="⇄   Permutas" />
                        <Button fx:id="btnPerfil"
                                onAction="#onPerfilClick"
                                maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="♙   Perfil" />
                        <Button fx:id="btnPreferencias"
                                onAction="#onPreferenciasClick"
                                maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="⚙   Prefer&#234;ncias" />
                        <Button fx:id="btnRelatorios"
                                onAction="#onRelatoriosHorasClick"
                                managed="false" maxWidth="Infinity"
                                styleClass="sidebar-btn"
                                text="▥   Relat&#243;rios"
                                visible="false" />
                    </VBox>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="10.0" styleClass="sidebar-footer">
                    <Label styleClass="sidebar-footer-title" text="FLUXO EDITORIAL" />
                    <Label styleClass="sidebar-footer-copy"
                           text="Centraliza hor&#225;rios, equipa, pedidos e auditoria."
                           wrapText="true" />
                    <Button fx:id="btnFecharAplicacao"
                            onAction="#onFecharAplicacaoClick"
                            maxWidth="Infinity"
                            styleClass="botao-fechar-app"
                            text="Fechar aplica&#231;&#227;o" />
                </VBox>
            </bottom>

        </BorderPane>
    </left>

</BorderPane>
