<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:id="mainContainer" prefHeight="920.0" prefWidth="1480.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-header" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="36.0" right="36.0" top="22.0" />
            </padding>
            <children>
                <Label fx:id="lblTopPageTitle" styleClass="top-header-page-title" text="OS MEUS PRÓXIMOS TURNOS" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="26.0">
                    <children>
                        <Button fx:id="btnTopoVisaoGeral" mnemonicParsing="false" onAction="#onTopVisaoGeralClick" styleClass="top-nav-button, top-nav-button-ativo" text="Visão geral" />
                        <Button fx:id="btnTopoPedidos" mnemonicParsing="false" onAction="#onTopPedidosClick" styleClass="top-nav-button" text="Pedidos" />
                        <Button fx:id="btnTopoPerfil" mnemonicParsing="false" onAction="#onTopPerfilClick" styleClass="top-nav-button" text="Perfil" />
                    </children>
                </HBox>
                <Region minWidth="24.0" />
                <HBox fx:id="boxPesquisa" alignment="CENTER_LEFT" prefWidth="320.0" styleClass="pesquisa-shell">
                    <children>
                        <StackPane styleClass="pesquisa-icone-box">
                            <children>
                                <SVGPath content="M15.5 14H14.71L14.43 13.73C15.41 12.59 16 11.11 16 9.5C16 5.91 13.09 3 9.5 3C5.91 3 3 5.91 3 9.5C3 13.09 5.91 16 9.5 16C11.11 16 12.59 15.41 13.73 14.43L14 14.71V15.5L19 20.49L20.49 19L15.5 14ZM9.5 14C7.01 14 5 11.99 5 9.5C5 7.01 7.01 5 9.5 5C11.99 5 14 7.01 14 9.5C14 11.99 11.99 14 9.5 14Z" styleClass="pesquisa-icone" />
                            </children>
                        </StackPane>
                        <TextField fx:id="txtPesquisa" promptText="Procurar ações, páginas ou tarefas" styleClass="pesquisa-input" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Region minWidth="16.0" />
                <Button onAction="#onLogoutClick" styleClass="botao-logout" text="Terminar sessão" />
            </children>
        </HBox>
    </top>

    <left>
        <BorderPane prefWidth="286.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <top>
                <VBox>
                    <children>
                        <VBox spacing="6.0" styleClass="sidebar-brand">
                            <children>
                                <Label styleClass="sidebar-titulo" text="LEVI'S" />
                                <Label styleClass="sidebar-subtitulo" text="Portal interno" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onTopPerfilClick" spacing="12.0" styleClass="sidebar-user-row sidebar-user-row-clickable">
                            <children>
                                <StackPane styleClass="sidebar-avatar">
                                    <children>
                                        <Label fx:id="lblAvatarInicial" styleClass="sidebar-avatar-text" text="L" />
                                    </children>
                                </StackPane>
                                <Label fx:id="lblUtilizadorSidebar" styleClass="sidebar-user-greeting" text="Olá, Staff!" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox spacing="2.0" styleClass="sidebar-menu">
                            <children>
                                <Button fx:id="btnDashboard" maxWidth="1.7976931348623157E308" onAction="#onDashboardHomeClick" styleClass="sidebar-btn, sidebar-btn-ativo" text="Painel" />
                                <Button fx:id="btnGestaoLoja" managed="false" maxWidth="1.7976931348623157E308" onAction="#onGestaoLojaClick" styleClass="sidebar-btn" text="Loja e regras" visible="false" />
                                <Button fx:id="btnGestaoFuncionarios" managed="false" maxWidth="1.7976931348623157E308" onAction="#onGestaoFuncionariosClick" styleClass="sidebar-btn" text="Funcionários" visible="false" />
                                <Button fx:id="btnHorarios" managed="false" maxWidth="1.7976931348623157E308" onAction="#onHorariosClick" styleClass="sidebar-btn" text="Horários" visible="false" />
                                <Button fx:id="btnPainelGerente" managed="false" maxWidth="1.7976931348623157E308" onAction="#onPainelGerentePedidosClick" styleClass="sidebar-btn" text="Painel do gerente" visible="false" />
                                <Button fx:id="btnAuditoria" managed="false" maxWidth="1.7976931348623157E308" onAction="#onPainelAuditoriaClick" styleClass="sidebar-btn" text="Auditoria" visible="false" />
                                <Button fx:id="btnFolgas" maxWidth="1.7976931348623157E308" onAction="#onPedirFolgaClick" styleClass="sidebar-btn" text="Pedir folga" />
                                <Button fx:id="btnPermutas" maxWidth="1.7976931348623157E308" onAction="#onTrocarTurnoClick" styleClass="sidebar-btn" text="Trocar turno" />
                                <Button fx:id="btnPerfil" maxWidth="1.7976931348623157E308" onAction="#onPerfilClick" styleClass="sidebar-btn" text="Perfil" />
                                <Button fx:id="btnPreferencias" maxWidth="1.7976931348623157E308" onAction="#onPreferenciasClick" styleClass="sidebar-btn" text="Preferências" />
                                <Button fx:id="btnRelatorios" managed="false" maxWidth="1.7976931348623157E308" onAction="#onRelatoriosHorasClick" styleClass="sidebar-btn" text="Relatórios" visible="false" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="14.0" styleClass="sidebar-footer">
                    <children>
                        <Label styleClass="sidebar-footer-title" text="Fluxo editorial" />
                        <Label styleClass="sidebar-footer-copy" text="Centraliza horários, equipa, pedidos e auditoria num único espaço de operação." wrapText="true" />
                        <Button fx:id="btnFecharAplicacao" onAction="#onFecharAplicacaoClick" styleClass="botao-fechar-app" text="Fechar aplicação" />
                    </children>
                </VBox>
            </bottom>
        </BorderPane>
    </left>

</BorderPane>
