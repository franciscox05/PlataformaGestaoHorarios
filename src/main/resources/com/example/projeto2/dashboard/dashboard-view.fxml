<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer" prefHeight="650.0" prefWidth="1000.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.DashboardController">

    <top>
        <HBox alignment="CENTER_RIGHT" styleClass="top-header" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <Region HBox.hgrow="ALWAYS" /> <Button onAction="#onLogoutClick" styleClass="botao-logout" text="Terminar Sessão 🚪" />
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" BorderPane.alignment="CENTER">

            <Label styleClass="sidebar-titulo" text="Levi's Portal" />

            <Button fx:id="btnDashboard" onAction="#onDashboardHomeClick" styleClass="sidebar-btn, sidebar-btn-ativo" text="📊 Dashboard" />
            <Button fx:id="btnFolgas" onAction="#onPedirFolgaClick" styleClass="sidebar-btn" text="🏖️ Pedir Folga" />
            <Button fx:id="btnPermutas" onAction="#onTrocarTurnoClick" styleClass="sidebar-btn" text="🔄 Trocar Turno" />

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
    </center>

</BorderPane>