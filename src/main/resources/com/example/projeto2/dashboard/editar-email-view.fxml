<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" styleClass="modal-card"
      stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.projeto2.DESKTOP.EditarEmailController">

    <padding>
        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
    </padding>

    <!-- Cabeçalho -->
    <VBox spacing="4.0">
                <Label styleClass="titulo-dashboard, modal-titulo" text="Editar Email" />
        <Label styleClass="texto-ajuda"
               text="Atualiza o teu email de contacto associado a esta conta."
               wrapText="true" />
    </VBox>

    <!-- Campos -->
    <VBox spacing="6.0">
        <Label styleClass="campo-titulo" text="Email atual" />
        <TextField fx:id="txtEmailAtual" editable="false" focusTraversable="false"
                   maxWidth="Infinity" styleClass="campo-readonly" />
    </VBox>

    <VBox spacing="6.0">
        <Label styleClass="campo-titulo" text="Novo email" />
        <TextField fx:id="txtEmailNovo" maxWidth="Infinity"
                   promptText="Ex: nome@empresa.com" styleClass="campo-input" />
    </VBox>

    <Label fx:id="lblErro" managed="false"
                       styleClass="mensagem-feedback, mensagem-erro"
           text="Não foi possível guardar." visible="false" wrapText="true" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Button cancelButton="true" onAction="#onCancelarClick"
                styleClass="botao-secundario" text="Cancelar" />
        <Button defaultButton="true" onAction="#onGuardarClick"
                styleClass="botao-acao" text="Alterar" />
    </HBox>

</VBox>
