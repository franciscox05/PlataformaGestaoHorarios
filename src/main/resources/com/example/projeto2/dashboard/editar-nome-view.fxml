<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="380.0" spacing="15.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.EditarNomeController">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label style="-fx-font-size: 20px;" styleClass="titulo-dashboard" text="Editar Nome" />

    <VBox alignment="CENTER_LEFT" spacing="5.0">
        <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Nome Atual:" />
        <TextField fx:id="txtNomeAtual" editable="false" focusTraversable="false" style="-fx-pref-width: 320px; -fx-padding: 8px; -fx-background-color: #e9ecef; -fx-text-fill: #6c757d; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
    </VBox>

    <VBox alignment="CENTER_LEFT" spacing="5.0">
        <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Novo Nome:" />
        <TextField fx:id="txtNomeNovo" promptText="Ex: Francisco Silva" style="-fx-pref-width: 320px; -fx-padding: 8px;" />
    </VBox>

    <Label fx:id="lblErro" style="-fx-text-fill: #cc0000; -fx-font-weight: bold;" visible="false" />

    <HBox alignment="CENTER" spacing="15.0">
        <padding>
            <Insets top="15.0" />
        </padding>

        <Button defaultButton="true" onAction="#onGuardarClick" styleClass="botao-acao" text="Alterar" />
        <Button cancelButton="true" onAction="#onCancelarClick" styleClass="botao-secundario" text="Cancelar" />
    </HBox>

</VBox>
