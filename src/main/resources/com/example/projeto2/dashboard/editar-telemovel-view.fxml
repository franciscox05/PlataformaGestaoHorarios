<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="320.0" prefWidth="390.0" spacing="15.0" styleClass="modal-card" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.EditarTelemovelController">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label styleClass="titulo-dashboard modal-titulo" text="Editar Telemovel" />
    <Label styleClass="texto-ajuda" text="Atualiza o numero de contacto usado no teu perfil de colaborador." wrapText="true" />

    <VBox alignment="CENTER_LEFT" spacing="5.0">
        <Label styleClass="campo-titulo" text="Numero atual" />
        <TextField fx:id="txtTelemovelAtual" editable="false" focusTraversable="false" styleClass="campo-readonly" />
    </VBox>

    <VBox alignment="CENTER_LEFT" spacing="5.0">
        <Label styleClass="campo-titulo" text="Novo numero" />
        <TextField fx:id="txtTelemovel" promptText="Ex: 912345678" styleClass="campo-input" />
    </VBox>

    <Label fx:id="lblErro" managed="false" styleClass="mensagem-feedback mensagem-erro" text="Nao foi possivel guardar." visible="false" wrapText="true" />

    <HBox alignment="CENTER" spacing="15.0">
        <padding>
            <Insets top="15.0" />
        </padding>

        <Button defaultButton="true" onAction="#onGuardarClick" styleClass="botao-acao" text="Alterar" />
        <Button cancelButton="true" onAction="#onCancelarClick" styleClass="botao-secundario" text="Cancelar" />
    </HBox>

</VBox>
