<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox styleClass="conteudo-pagina, modulo-com-abas"
      stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.projeto2.DESKTOP.GeracaoHorariosController">

    <!-- ░░ CABEÇALHO ░░ -->
    <VBox spacing="8.0" styleClass="modulo-banner modulo-banner-card modulo-banner-horarios"
          style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #9b1c1c 0%, #450a0a 100%); -fx-background-insets: 0; -fx-background-radius: 16px;">
        <VBox.margin><Insets top="40.0" right="40.0" bottom="24.0" left="40.0"/></VBox.margin>
        <padding><Insets top="26.0" right="30.0" bottom="26.0" left="30.0"/></padding>
        <Label styleClass="modulo-titulo" text="Gera&#231;&#227;o de hor&#225;rios"/>
        <Label styleClass="modulo-subtitulo"
               text="Segue os 4 passos: configura o per&#237;odo, gera alternativas, rev&#234; e envia ao supervisor."
               wrapText="true"/>
    </VBox>

    <!-- ░░ STEPPER DE FLUXO (navegação real do assistente) ░░ -->
    <HBox styleClass="geracao-stepper" alignment="CENTER">
        <padding><Insets top="8.0" right="40.0" bottom="8.0" left="40.0"/></padding>

        <VBox fx:id="stepperPasso1" alignment="CENTER" styleClass="stepper-passo, stepper-passo-ativo" minWidth="86.0">
            <Label styleClass="stepper-numero" text="1"/>
            <Label styleClass="stepper-rotulo" text="Configurar"/>
        </VBox>
        <Region styleClass="stepper-linha" HBox.hgrow="ALWAYS"/>
        <VBox fx:id="stepperPasso2" alignment="CENTER" styleClass="stepper-passo, stepper-passo-inativo" minWidth="86.0">
            <Label styleClass="stepper-numero" text="2"/>
            <Label styleClass="stepper-rotulo" text="Alternativas"/>
        </VBox>
        <Region styleClass="stepper-linha" HBox.hgrow="ALWAYS"/>
        <VBox fx:id="stepperPasso3" alignment="CENTER" styleClass="stepper-passo, stepper-passo-inativo" minWidth="86.0">
            <Label styleClass="stepper-numero" text="3"/>
            <Label styleClass="stepper-rotulo" text="Rever"/>
        </VBox>
        <Region styleClass="stepper-linha" HBox.hgrow="ALWAYS"/>
        <VBox fx:id="stepperPasso4" alignment="CENTER" styleClass="stepper-passo, stepper-passo-inativo" minWidth="86.0">
            <Label styleClass="stepper-numero" text="4"/>
            <Label styleClass="stepper-rotulo" text="Enviar"/>
        </VBox>
    </HBox>

    <!-- ░░ CORPO DO ASSISTENTE (TabPane sem cabeçalhos = wizard) ░░ -->
    <TabPane fx:id="tabPaneHorarios" styleClass="modulo-tabs, wizard-tabs"
             tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>

            <!-- ═══════════════ PASSO ① — CONFIGURAR ═══════════════ -->
            <Tab text="Configurar">
                <content>
                    <VBox>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="conteudo-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="aba-conteudo">
                                    <padding><Insets top="24.0" right="40.0" bottom="32.0" left="40.0"/></padding>

                                    <!-- Intro do passo -->
                                    <HBox styleClass="passo-intro">
                                        <Label styleClass="passo-intro-num" text="1"/>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="passo-intro-titulo" text="Configurar o per&#237;odo e a equipa"/>
                                            <Label styleClass="passo-intro-sub"
                                                   text="Escolhe o m&#234;s, confirma a loja e seleciona quem entra no hor&#225;rio. Depois clica em Gerar."/>
                                        </VBox>
                                    </HBox>

                                    <VBox spacing="16.0" styleClass="bento-card">

                                        <!-- Contexto da loja -->
                                        <HBox spacing="24.0" styleClass="bento-card-accent">
                                            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Loja"/>
                                                <Label fx:id="lblLoja" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Localiza&#231;&#227;o"/>
                                                <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                        </HBox>

                                        <!-- Período -->
                                        <HBox spacing="12.0">
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="campo-titulo" text="M&#234;s"/>
                                                <ComboBox fx:id="cbMes" maxWidth="Infinity"
                                                          promptText="Seleciona o m&#234;s" styleClass="campo-combo"/>
                                            </VBox>
                                            <VBox spacing="5.0" HBox.hgrow="NEVER">
                                                <Label styleClass="campo-titulo" text="Ano"/>
                                                <Spinner fx:id="spAno"/>
                                            </VBox>
                                        </HBox>

                                        <!-- Seleção de colaboradores -->
                                        <VBox fx:id="painelSelecaoColaboradores" spacing="9.0">
                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                <Label styleClass="campo-titulo"
                                                       text="Funcion&#225;rios inclu&#237;dos na gera&#231;&#227;o"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="btnSelecionarTodosColaboradores"
                                                        onAction="#onSelecionarTodosColaboradoresClick"
                                                        styleClass="botao-secundario, topo-botao-curto" text="Todos"/>
                                                <Button fx:id="btnLimparColaboradores"
                                                        onAction="#onLimparColaboradoresClick"
                                                        styleClass="botao-secundario, topo-botao-curto" text="Limpar"/>
                                            </HBox>
                                            <Label fx:id="lblResumoColaboradoresGeracao" styleClass="bento-card-subtitulo"
                                                   text="Escolhe o per&#237;odo para carregar a equipa eleg&#237;vel."
                                                   wrapText="true"/>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" minHeight="140.0"
                                                        styleClass="selecao-colaboradores-scroll">
                                                <content>
                                                    <VBox fx:id="boxColaboradoresGeracao" spacing="8.0"
                                                          styleClass="selecao-colaboradores-lista"/>
                                                </content>
                                            </ScrollPane>
                                        </VBox>
                                    </VBox>

                                    <!-- Card de geração -->
                                    <VBox spacing="16.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#c91428"
                                                         content="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="stat-kicker" text="GERAR"/>
                                                <Label styleClass="bento-card-titulo" text="Criar alternativas de hor&#225;rio"/>
                                            </VBox>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                                            <Button fx:id="btnGerarProposta" onAction="#onGerarPropostaClick"
                                                    styleClass="btn-gerar-primario" text="&#9889;  Gerar hor&#225;rio"/>
                                            <Region minWidth="8.0"/>
                                            <VBox spacing="5.0" HBox.hgrow="NEVER">
                                                <Label styleClass="campo-titulo" text="Quantas alternativas"/>
                                                <Spinner fx:id="spQuantidadeAlternativas"/>
                                            </VBox>
                                            <Button fx:id="btnGerarAlternativas" onAction="#onGerarAlternativasClick"
                                                    styleClass="botao-secundario" text="Gerar v&#225;rias"/>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <Button fx:id="btnVerProposta" onAction="#onVerPropostaClick"
                                                    styleClass="botao-secundario" text="Ver planeamento publicado"/>
                                            <Button fx:id="btnVerCriterios" onAction="#onVerCriteriosClick"
                                                    styleClass="botao-secundario" text="&#128269;  O que &#233; considerado?"/>
                                            <Label styleClass="texto-atalho"
                                                   text="Atalhos: Ctrl+G gerar 1 &#183; Ctrl+L gerar v&#225;rias &#183; Ctrl+Enter consultar"
                                                   wrapText="true"/>
                                        </HBox>

                                        <!-- Guia de fluxo contextual -->
                                        <Label fx:id="lblGuiaFluxo" styleClass="guia-fluxo"
                                               text="Configura o per&#237;odo, seleciona a equipa e clica em Gerar hor&#225;rio."
                                               wrapText="true"/>

                                        <!-- Feedback de operação -->
                                        <Label fx:id="lblFeedback" managed="false" styleClass="mensagem-feedback"
                                               visible="false" wrapText="true"/>

                                        <!-- Painel de diagnóstico (aparece quando a geração falha) -->
                                        <VBox fx:id="painelDiagnosticoGeracao" managed="false" spacing="10.0"
                                              styleClass="diagnostico-geracao" visible="false">
                                            <Label fx:id="lblDiagnosticoTitulo" styleClass="diagnostico-titulo"
                                                   text="Porque n&#227;o foi poss&#237;vel gerar" wrapText="true"/>
                                            <Label fx:id="lblDiagnosticoResumo" styleClass="diagnostico-resumo"
                                                   wrapText="true"/>
                                            <VBox fx:id="boxDiagnosticoMotivos" spacing="8.0"/>
                                            <Label styleClass="diagnostico-titulo" text="Sugest&#245;es para resolver"
                                                   wrapText="true"/>
                                            <VBox fx:id="boxDiagnosticoSugestoes" spacing="8.0"/>
                                            <Label fx:id="lblDiagnosticoPerfilRecomendado" managed="false"
                                                   styleClass="diagnostico-reforco" visible="false" wrapText="true"/>
                                        </VBox>
                                    </VBox>

                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Footer de navegação -->
                        <HBox styleClass="wizard-footer" alignment="CENTER_RIGHT">
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnPasso1Continuar" onAction="#onIrAlternativas"
                                    styleClass="btn-wizard-continuar" text="Ver alternativas  &#8594;"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ═══════════════ PASSO ② — ALTERNATIVAS ═══════════════ -->
            <Tab text="Alternativas">
                <content>
                    <VBox>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="conteudo-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="aba-conteudo">
                                    <padding><Insets top="24.0" right="40.0" bottom="32.0" left="40.0"/></padding>

                                    <!-- Intro do passo -->
                                    <HBox styleClass="passo-intro">
                                        <Label styleClass="passo-intro-num" text="2"/>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="passo-intro-titulo" text="Comparar e escolher uma alternativa"/>
                                            <Label fx:id="lblPeriodoPropostas" styleClass="passo-intro-sub"
                                                   text="Seleciona um m&#234;s e gera uma proposta"/>
                                        </VBox>
                                    </HBox>

                                    <!-- STAT CARDS -->
                                    <HBox spacing="16.0">
                                        <VBox alignment="CENTER" spacing="12.0"
                                              styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="52.0" minHeight="52.0">
                                                <SVGPath fill="#2563eb"
                                                         content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                                         styleClass="stat-icon"/>
                                            </StackPane>
                                            <Label fx:id="lblTotalColaboradores" styleClass="stat-numero" text="0"/>
                                            <Label styleClass="stat-titulo" text="Colaboradores"/>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="12.0"
                                              styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                                            <StackPane styleClass="stat-icon-wrap-red" minWidth="52.0" minHeight="52.0">
                                                <SVGPath fill="#c91428"
                                                         content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"
                                                         styleClass="stat-icon"/>
                                            </StackPane>
                                            <Label fx:id="lblTotalTurnos" styleClass="stat-numero" text="0"/>
                                            <Label styleClass="stat-titulo" text="Turnos gerados"/>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="12.0"
                                              styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                                            <StackPane styleClass="stat-icon-wrap-green" minWidth="52.0" minHeight="52.0">
                                                <SVGPath fill="#16a34a"
                                                         content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                                         styleClass="stat-icon"/>
                                            </StackPane>
                                            <Label fx:id="lblTotalDiasCobertos" styleClass="stat-numero" text="0"/>
                                            <Label styleClass="stat-titulo" text="Dias cobertos"/>
                                        </VBox>
                                    </HBox>

                                    <!-- ALTERNATIVAS GERADAS (tabela de propostas) -->
                                    <VBox spacing="16.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-green" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#16a34a"
                                                         content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="stat-kicker" text="RASCUNHOS"/>
                                                <Label styleClass="bento-card-titulo" text="Alternativas geradas"/>
                                            </VBox>
                                        </HBox>
                                        <Label styleClass="bento-card-subtitulo"
                                               text="Clica numa alternativa para a escolher. Podes comparar duas em baixo antes de avan&#231;ar para Rever."
                                               wrapText="true"/>
                                        <VBox fx:id="emptyStatePropostas" alignment="CENTER" spacing="12.0"
                                              styleClass="empty-state-box">
                                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>
                                            <SVGPath fill="#dddddd"
                                                     content="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"
                                                     styleClass="empty-state-icon"/>
                                            <Label styleClass="empty-state-titulo" text="Sem alternativas geradas"/>
                                            <Label styleClass="empty-state-subtitulo"
                                                   text="Volta ao passo 1 (Configurar) e clica em 'Gerar hor&#225;rio' para come&#231;ar."
                                                   wrapText="true"/>
                                        </VBox>
                                        <TableView fx:id="tabelaPropostas" styleClass="tabela-premium"
                                                   VBox.vgrow="ALWAYS">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colPropostaRotulo"    text="Proposta"/>
                                                <TableColumn fx:id="colPropostaEstado"    text="Estado"/>
                                                <TableColumn fx:id="colPropostaData"      text="Gerada em"/>
                                                <TableColumn fx:id="colPropostaScore"     text="Score"/>
                                                <TableColumn fx:id="colPropostaQualidade" text="Qualidade"/>
                                                <TableColumn fx:id="colPropostaTurnos"    text="Turnos"/>
                                            </columns>
                                        </TableView>
                                    </VBox>

                                    <!-- COMPARAÇÃO DE ALTERNATIVAS -->
                                    <VBox spacing="16.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-orange" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#ea580c"
                                                         content="M9 3L5 6.99h3V14h2V6.99h3L9 3zm7 14.01V10h-2v7.01h-3L15 21l4-3.99h-3z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0">
                                                <Label styleClass="stat-kicker" text="AN&#193;LISE"/>
                                                <Label styleClass="bento-card-titulo" text="Compara&#231;&#227;o de alternativas"/>
                                            </VBox>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <ComboBox fx:id="cbComparacaoBase" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                                      promptText="Alternativa base" styleClass="campo-combo"/>
                                            <ComboBox fx:id="cbComparacaoAlvo" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                                      promptText="Alternativa a comparar" styleClass="campo-combo"/>
                                            <Button fx:id="btnCompararPropostas" onAction="#onCompararPropostasClick"
                                                    styleClass="botao-acao" text="Comparar"/>
                                        </HBox>
                                        <Label fx:id="lblResumoComparacao" styleClass="bento-card-subtitulo"
                                               text="Seleciona duas alternativas para comparar distribui&#231;&#227;o, carga hor&#225;ria e impacto por colaborador."
                                               wrapText="true"/>
                                        <TableView fx:id="tabelaComparacao" styleClass="tabela-premium"
                                                   VBox.vgrow="ALWAYS">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colComparacaoColaborador" text="Colaborador"/>
                                                <TableColumn fx:id="colComparacaoBase"        text="Base"/>
                                                <TableColumn fx:id="colComparacaoAlvo"        text="Comparada"/>
                                                <TableColumn fx:id="colComparacaoDiferenca"   text="Diferen&#231;a"/>
                                            </columns>
                                        </TableView>
                                    </VBox>

                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Footer de navegação -->
                        <HBox styleClass="wizard-footer" alignment="CENTER_LEFT">
                            <Button onAction="#onIrConfigurar"
                                    styleClass="btn-wizard-voltar" text="&#8592;  Configurar"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnPasso2Continuar" onAction="#onIrRever"
                                    styleClass="btn-wizard-continuar" text="Rever proposta  &#8594;"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ═══════════════ PASSO ③ — REVER ═══════════════ -->
            <Tab text="Rever">
                <content>
                    <VBox>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="conteudo-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="aba-conteudo">
                                    <padding><Insets top="24.0" right="40.0" bottom="32.0" left="40.0"/></padding>

                                    <!-- Intro do passo -->
                                    <HBox styleClass="passo-intro">
                                        <Label styleClass="passo-intro-num" text="3"/>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="passo-intro-titulo" text="Rever a proposta escolhida"/>
                                            <Label styleClass="passo-intro-sub"
                                                   text="Confirma a distribui&#231;&#227;o por colaborador e o calend&#225;rio antes de enviar."/>
                                        </VBox>
                                    </HBox>

                                    <!-- DETALHE DA PROPOSTA SELECIONADA -->
                                    <VBox spacing="20.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#2563eb"
                                                         content="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0">
                                                <Label styleClass="stat-kicker" text="DETALHE"/>
                                                <Label styleClass="bento-card-titulo"
                                                       text="Resumo da proposta selecionada"/>
                                            </VBox>
                                        </HBox>

                                        <HBox spacing="20.0">
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Estado"/>
                                                <Label fx:id="lblEstadoProposta" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Origem"/>
                                                <Label fx:id="lblOrigemPlaneamento" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Pol&#237;tica IO"/>
                                                <Label fx:id="lblPoliticaOtimizacao" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Score"/>
                                                <Label fx:id="lblPontuacaoOtimizacao" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                        </HBox>
                                        <HBox spacing="20.0">
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Gerado por"/>
                                                <Label fx:id="lblGeradoPor" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Data de gera&#231;&#227;o"/>
                                                <Label fx:id="lblDataGeracao" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Decidido por"/>
                                                <Label fx:id="lblDecididoPor" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Data da decis&#227;o"/>
                                                <Label fx:id="lblDataDecisao" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                        </HBox>
                                        <HBox spacing="20.0">
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Desvio m&#233;dio de carga"/>
                                                <Label fx:id="lblDesvioCarga" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta" text="Amplitude de carga"/>
                                                <Label fx:id="lblAmplitudeCarga" styleClass="meta-valor" text="-"/>
                                            </VBox>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <Label styleClass="meta-etiqueta"
                                                       text="Observa&#231;&#245;es do supervisor"/>
                                                <Label fx:id="lblObservacoesSupervisor" styleClass="meta-valor"
                                                       text="-" wrapText="true"/>
                                            </VBox>
                                        </HBox>

                                        <VBox spacing="6.0">
                                            <Label styleClass="campo-titulo"
                                                   text="Observa&#231;&#245;es da gera&#231;&#227;o"/>
                                            <Label fx:id="lblResumoGeracao" styleClass="bento-card-subtitulo"
                                                   text="Ainda n&#227;o existe uma proposta carregada." wrapText="true"/>
                                        </VBox>
                                    </VBox>

                                    <!-- DISTRIBUIÇÃO POR COLABORADOR -->
                                    <VBox spacing="16.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#2563eb"
                                                         content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0">
                                                <Label styleClass="stat-kicker" text="EQUIPA"/>
                                                <Label styleClass="bento-card-titulo"
                                                       text="Distribui&#231;&#227;o por colaborador"/>
                                            </VBox>
                                        </HBox>
                                        <Label styleClass="bento-card-subtitulo"
                                               text="Duplo clique num colaborador para ver o hor&#225;rio completo do m&#234;s."
                                               wrapText="true"/>
                                        <VBox fx:id="emptyStateDistribuicao" alignment="CENTER" spacing="12.0"
                                              styleClass="empty-state-box">
                                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>
                                            <SVGPath fill="#dddddd"
                                                     content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                                     styleClass="empty-state-icon"/>
                                            <Label styleClass="empty-state-titulo"
                                                   text="Sem dados de distribui&#231;&#227;o"/>
                                            <Label styleClass="empty-state-subtitulo"
                                                   text="Gera ou seleciona uma proposta para ver a distribui&#231;&#227;o."
                                                   wrapText="true"/>
                                        </VBox>
                                        <TableView fx:id="tabelaResumoColaboradores" styleClass="tabela-premium"
                                                   VBox.vgrow="ALWAYS">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colResumoColaborador" text="Colaborador"/>
                                                <TableColumn fx:id="colResumoCargo"       text="Cargo"/>
                                                <TableColumn fx:id="colResumoTurnos"      text="Turnos"/>
                                                <TableColumn fx:id="colResumoHoras"       text="Horas"/>
                                            </columns>
                                        </TableView>
                                    </VBox>

                                    <!-- TOGGLE CALENDÁRIO / GRELHA -->
                                    <HBox alignment="CENTER_LEFT" spacing="16.0">
                                        <HBox styleClass="vista-toggle-bar" spacing="4.0">
                                            <Button fx:id="btnVistaCalendario"
                                                    onAction="#onVistaCalendarioClick"
                                                    styleClass="btn-vista btn-vista-ativo"
                                                    text="&#128197;  Calend&#225;rio"/>
                                            <Button fx:id="btnVistaGrelha"
                                                    onAction="#onVistaGrelhaClick"
                                                    styleClass="btn-vista btn-vista-inativo"
                                                    text="&#9635;  Grelha"/>
                                        </HBox>
                                        <Label styleClass="bento-card-subtitulo"
                                               text="Alterna entre calend&#225;rio e grelha por colaborador"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="btnVerificarHorario"
                                                onAction="#onVerificarHorarioClick"
                                                styleClass="botao-secundario"
                                                text="&#10003;  Verificar hor&#225;rio"/>
                                    </HBox>

                                    <!-- ── PAINEL VISTA CALENDÁRIO ── -->
                                    <VBox fx:id="painelVistaCalendario" spacing="20.0">

                                        <!-- CALENDÁRIO SEMANAL -->
                                        <VBox spacing="16.0" styleClass="bento-card">
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                                                    <SVGPath fill="#c91428"
                                                             content="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                                             styleClass="card-icon"/>
                                                </StackPane>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label styleClass="stat-kicker" text="CALEND&#193;RIO SEMANAL"/>
                                                    <Label styleClass="bento-card-titulo"
                                                           text="Planeamento semana a semana"/>
                                                </VBox>
                                                <VBox spacing="4.0">
                                                    <Label styleClass="campo-titulo"
                                                           text="Filtrar por colaborador"/>
                                                    <ComboBox fx:id="cbFiltroColaborador" minWidth="200.0"
                                                              promptText="Toda a equipa" styleClass="campo-combo"/>
                                                </VBox>
                                                <Button onAction="#onSemanaPlaneamentoAnteriorClick"
                                                        styleClass="botao-nav" text="&#8249; Anterior"/>
                                                <Label fx:id="lblSemanaPlaneamento" styleClass="campo-titulo"
                                                       text="Semana"/>
                                                <Button onAction="#onSemanaPlaneamentoSeguinteClick"
                                                        styleClass="botao-nav" text="Seguinte &#8250;"/>
                                            </HBox>
                                            <Label styleClass="bento-card-subtitulo"
                                                   text="Clica num turno para editar."
                                                   wrapText="true"/>
                                            <VBox fx:id="emptyStateCalendario" alignment="CENTER" spacing="12.0"
                                                  styleClass="empty-state-box">
                                                <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>
                                                <SVGPath fill="#dddddd"
                                                         content="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                                         styleClass="empty-state-icon"/>
                                                <Label styleClass="empty-state-titulo"
                                                       text="Sem semana para mostrar"/>
                                                <Label styleClass="empty-state-subtitulo"
                                                       text="Seleciona uma proposta no passo Alternativas para ver o calend&#225;rio semanal."
                                                       wrapText="true"/>
                                            </VBox>
                                            <HBox fx:id="boxSemanaPlaneamento" spacing="10.0"
                                                  styleClass="calendario-semana"/>
                                        </VBox>

                                        <!-- CALENDÁRIO MENSAL -->
                                        <VBox spacing="16.0" styleClass="bento-card">
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                                                    <SVGPath fill="#c91428"
                                                             content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                                             styleClass="card-icon"/>
                                                </StackPane>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label styleClass="stat-kicker" text="CALEND&#193;RIO MENSAL"/>
                                                    <Label styleClass="bento-card-titulo"
                                                           text="Hor&#225;rio mensal da loja"/>
                                                </VBox>
                                                <Button fx:id="btnMesAnterior" onAction="#onMesAnteriorClick"
                                                        styleClass="botao-nav" text="&#8249; M&#234;s anterior"/>
                                                <Label fx:id="lblMesAtual" styleClass="calendar-month-label"
                                                       text="&#8212;"/>
                                                <Button fx:id="btnMesSeguinte" onAction="#onMesSeguinteClick"
                                                        styleClass="botao-nav" text="M&#234;s seguinte &#8250;"/>
                                                <Button fx:id="btnExportarCsvHorario"
                                                        onAction="#onExportarCsvHorarioClick"
                                                        disable="true" styleClass="botao-secundario"
                                                        text="Exportar CSV"/>
                                                <Button fx:id="btnExportarPdfHorario"
                                                        onAction="#onExportarPdfHorarioClick"
                                                        disable="true" styleClass="botao-secundario"
                                                        text="Exportar PDF"/>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <Label fx:id="lblIdentificacaoHorario"
                                                       styleClass="identificacao-horario-label"
                                                       text="Sem proposta carregada" HBox.hgrow="ALWAYS"/>
                                                <Label styleClass="campo-titulo" text="Ver proposta:"/>
                                                <ComboBox fx:id="cbSelecaoProposta" minWidth="240.0"
                                                          promptText="Seleciona uma proposta"
                                                          styleClass="campo-combo"/>
                                            </HBox>

                                            <VBox fx:id="emptyStateCalendarioMensal" alignment="CENTER" spacing="12.0"
                                                  styleClass="empty-state-box">
                                                <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>
                                                <SVGPath fill="#dddddd"
                                                         content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                                         styleClass="empty-state-icon"/>
                                                <Label styleClass="empty-state-titulo"
                                                       text="Sem hor&#225;rio mensal"/>
                                                <Label styleClass="empty-state-subtitulo"
                                                       text="Seleciona uma proposta para visualizar o calend&#225;rio mensal. Clica em qualquer dia para ver o detalhe dos turnos."
                                                       wrapText="true"/>
                                            </VBox>

                                            <GridPane fx:id="calendarioMensalGrid" hgap="8.0" vgap="8.0"
                                                      styleClass="calendar-grid">
                                                <columnConstraints>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.32"/>
                                                </columnConstraints>
                                            </GridPane>
                                        </VBox>

                                    </VBox>
                                    <!-- ── FIM PAINEL CALENDÁRIO ── -->

                                    <!-- ── PAINEL VISTA GRELHA ── -->
                                    <VBox fx:id="painelVistaGrelha" spacing="20.0" managed="false" visible="false">
                                        <VBox spacing="16.0" styleClass="bento-card">
                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                                                    <SVGPath fill="#c91428"
                                                             content="M3 5h18v2H3zm0 4h18v2H3zm0 4h18v2H3zm0 4h18v2H3z"
                                                             styleClass="card-icon"/>
                                                </StackPane>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label styleClass="stat-kicker" text="VISTA EM GRELHA"/>
                                                    <Label styleClass="bento-card-titulo"
                                                           text="Hor&#225;rio da equipa — linha por colaborador"/>
                                                </VBox>
                                                <HBox styleClass="vista-toggle-bar" spacing="4.0">
                                                    <Button fx:id="btnGrelhaSemana"
                                                            onAction="#onGrelhaSemanaClick"
                                                            styleClass="btn-grelha-sub-ativo"
                                                            text="Semana"/>
                                                    <Button fx:id="btnGrelhaMes"
                                                            onAction="#onGrelhaMesClick"
                                                            styleClass="btn-grelha-sub-inativo"
                                                            text="M&#234;s"/>
                                                </HBox>
                                                <Region minWidth="8.0"/>
                                                <Button fx:id="btnGrelhaAnterior"
                                                        onAction="#onGrelhaAnteriorClick"
                                                        styleClass="botao-nav" text="&#8249;"/>
                                                <Label fx:id="lblGrelhaPeriodo" styleClass="calendar-month-label"
                                                       text="&#8212;" minWidth="160.0"/>
                                                <Button fx:id="btnGrelhaSeguinte"
                                                        onAction="#onGrelhaSeguinteClick"
                                                        styleClass="botao-nav" text="&#8250;"/>
                                                <Region minWidth="4.0"/>
                                                <Button fx:id="btnExpandirGrelha"
                                                        onAction="#onExpandirGrelhaClick"
                                                        styleClass="botao-nav"
                                                        text="&#8599;"
                                                        managed="false" visible="false"/>
                                            </HBox>
                                            <Label styleClass="bento-card-subtitulo"
                                                   text="Vista matricial: colaboradores em linha, dias em coluna."
                                                   wrapText="true"/>

                                            <VBox fx:id="emptyStateGrelha" alignment="CENTER" spacing="12.0"
                                                  styleClass="empty-state-box">
                                                <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/></padding>
                                                <SVGPath fill="#dddddd"
                                                         content="M3 5h18v2H3zm0 4h12v2H3zm0 4h18v2H3zm0 4h12v2H3z"
                                                         styleClass="empty-state-icon"/>
                                                <Label styleClass="empty-state-titulo"
                                                       text="Sem hor&#225;rio para mostrar"/>
                                                <Label styleClass="empty-state-subtitulo"
                                                       text="Seleciona uma proposta no passo Alternativas para visualizar a grelha."
                                                       wrapText="true"/>
                                            </VBox>

                                            <ScrollPane fx:id="grelhaScrollPane"
                                                        fitToWidth="true"
                                                        fitToHeight="true"
                                                        hbarPolicy="NEVER"
                                                        vbarPolicy="NEVER"
                                                        styleClass="grelha-scroll"
                                                        minHeight="300.0"
                                                        managed="false" visible="false">
                                                <content>
                                                    <VBox fx:id="grelhaContainer" styleClass="grelha-container"/>
                                                </content>
                                            </ScrollPane>
                                        </VBox>
                                    </VBox>
                                    <!-- ── FIM PAINEL GRELHA ── -->

                                    <!-- ── PAINEL VERIFICAÇÃO DO HORÁRIO ── -->
                                    <VBox fx:id="painelVerificacaoHorario" spacing="16.0"
                                          managed="false" visible="false">

                                        <!-- Cabeçalho -->
                                        <VBox styleClass="bento-card" spacing="8.0">
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <Button onAction="#onVoltarAoHorarioClick"
                                                        styleClass="btn-wizard-voltar"
                                                        text="&#8592;  Horário"/>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label styleClass="stat-kicker"
                                                           text="VERIFICA&#199;&#195;O DO HOR&#193;RIO"/>
                                                    <Label fx:id="lblVerificacaoTitulo"
                                                           styleClass="bento-card-titulo"
                                                           text="&#8212;"/>
                                                </VBox>
                                            </HBox>
                                        </VBox>

                                        <!-- Conteúdo: grelha + resultados lado a lado -->
                                        <HBox spacing="16.0" alignment="TOP_LEFT">

                                            <!-- Esquerda: grelha compacta -->
                                            <VBox styleClass="bento-card" spacing="8.0"
                                                  HBox.hgrow="ALWAYS">
                                                <Label styleClass="stat-kicker"
                                                       text="HOR&#193;RIO DO M&#202;S"/>
                                                <Label styleClass="bento-card-subtitulo"
                                                       text="Clica num dia para o detalhe."
                                                       wrapText="true"/>
                                                <VBox fx:id="vbVerificacaoGrelha"/>
                                            </VBox>

                                            <!-- Direita: resultados de compliance -->
                                            <VBox fx:id="vbVerificacaoResultados"
                                                  spacing="6.0"
                                                  minWidth="340.0" prefWidth="380.0" maxWidth="420.0"/>

                                        </HBox>
                                    </VBox>
                                    <!-- ── FIM PAINEL VERIFICAÇÃO ── -->

                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Footer de navegação -->
                        <HBox styleClass="wizard-footer" alignment="CENTER_LEFT">
                            <Button onAction="#onIrAlternativas"
                                    styleClass="btn-wizard-voltar" text="&#8592;  Alternativas"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnPasso3Continuar" onAction="#onIrEnviar"
                                    styleClass="btn-wizard-continuar" text="Continuar  &#8594;"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ═══════════════ PASSO ④ — ENVIAR / DECIDIR ═══════════════ -->
            <Tab text="Enviar">
                <content>
                    <VBox>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="conteudo-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="aba-conteudo">
                                    <padding><Insets top="24.0" right="40.0" bottom="32.0" left="40.0"/></padding>

                                    <!-- Intro do passo -->
                                    <HBox styleClass="passo-intro">
                                        <Label styleClass="passo-intro-num" text="4"/>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="passo-intro-titulo" text="Enviar ou decidir"/>
                                            <Label styleClass="passo-intro-sub"
                                                   text="O gerente envia ao supervisor; o supervisor aprova ou rejeita."/>
                                        </VBox>
                                    </HBox>

                                    <!-- CARD DE ENVIO (gerente) -->
                                    <VBox fx:id="painelEnvioGerente" spacing="14.0" styleClass="envio-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#2563eb"
                                                         content="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0">
                                                <Label styleClass="stat-kicker" text="GERENTE"/>
                                                <Label styleClass="bento-card-titulo"
                                                       text="Enviar alternativas ao supervisor"/>
                                            </VBox>
                                        </HBox>
                                        <Label styleClass="bento-card-subtitulo"
                                               text="O supervisor s&#243; valida alternativas enviadas pelo gerente. Seleciona no passo Alternativas as que queres enviar (Ctrl+clique para v&#225;rias)."
                                               wrapText="true"/>
                                        <Label fx:id="lblResumoEnvio" styleClass="envio-resumo"
                                               text="Nenhuma alternativa selecionada para enviar." wrapText="true"/>
                                        <HBox alignment="CENTER_LEFT">
                                            <Button fx:id="btnEnviarSupervisor" onAction="#onEnviarSupervisorClick"
                                                    styleClass="btn-gerar-primario"
                                                    text="&#128228;  Enviar ao supervisor"/>
                                        </HBox>
                                    </VBox>

                                    <!-- VALIDAÇÃO DO SUPERVISOR -->
                                    <VBox fx:id="painelValidacaoSupervisor" spacing="16.0" styleClass="bento-card">
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <StackPane styleClass="stat-icon-wrap-green" minWidth="40.0" minHeight="40.0">
                                                <SVGPath fill="#16a34a"
                                                         content="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"
                                                         styleClass="card-icon"/>
                                            </StackPane>
                                            <VBox spacing="2.0">
                                                <Label styleClass="stat-kicker" text="SUPERVISOR"/>
                                                <Label styleClass="bento-card-titulo"
                                                       text="Valida&#231;&#227;o da proposta"/>
                                            </VBox>
                                        </HBox>
                                        <Label styleClass="bento-card-subtitulo"
                                               text="Rev&#234; a proposta selecionada. Ao aprovar, as restantes pendentes do mesmo m&#234;s s&#227;o rejeitadas automaticamente."
                                               wrapText="true"/>
                                        <VBox spacing="6.0">
                                            <Label styleClass="campo-titulo"
                                                   text="Observa&#231;&#245;es da decis&#227;o"/>
                                            <TextArea fx:id="txtObservacoesSupervisor" prefRowCount="3"
                                                      promptText="Opcional: acrescenta observa&#231;&#245;es para o hist&#243;rico da decis&#227;o."
                                                      styleClass="campo-textarea" wrapText="true"/>
                                        </VBox>
                                        <Label fx:id="lblFeedbackValidacao" managed="false" visible="false"
                                               wrapText="true"/>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <Button fx:id="btnRejeitarProposta" onAction="#onRejeitarPropostaClick"
                                                    styleClass="botao-secundario" text="Rejeitar proposta"/>
                                            <Button fx:id="btnAprovarProposta" onAction="#onAprovarPropostaClick"
                                                    styleClass="botao-acao" text="Aprovar e publicar"/>
                                        </HBox>
                                    </VBox>

                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Footer de navegação -->
                        <HBox styleClass="wizard-footer" alignment="CENTER_LEFT">
                            <Button onAction="#onIrRever"
                                    styleClass="btn-wizard-voltar" text="&#8592;  Rever"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

