<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="600.0" prefWidth="730.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.GeracaoHorariosController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="18.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label styleClass="titulo-dashboard" text="Horários da loja" />
                <Label styleClass="subtitulo" text="Gera, consulta e valida a proposta mensal da tua loja com base nas regras configuradas, na equipa ativa e nas ausências ou preferências já aprovadas." wrapText="true" />

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Período de planeamento" />

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Loja" />
                                        <Label fx:id="lblLoja" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Localização" />
                                        <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="12.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Mês" />
                                        <ComboBox fx:id="cbMes" promptText="Seleciona o mês" styleClass="campo-combo" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Ano" />
                                        <Spinner fx:id="spAno" prefWidth="120.0" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button fx:id="btnVerProposta" onAction="#onVerPropostaClick" styleClass="botao-secundario" text="Ver planeamento" />
                                <Button fx:id="btnGerarProposta" onAction="#onGerarPropostaClick" styleClass="botao-acao" text="Gerar proposta" />
                            </children>
                        </HBox>

                        <Label fx:id="lblFeedback" managed="false" styleClass="mensagem-feedback" visible="false" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Resumo do planeamento" />

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Estado" />
                                        <Label fx:id="lblEstadoProposta" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Origem" />
                                        <Label fx:id="lblOrigemPlaneamento" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Gerado por" />
                                        <Label fx:id="lblGeradoPor" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Data de geração" />
                                        <Label fx:id="lblDataGeracao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Decidido por" />
                                        <Label fx:id="lblDecididoPor" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Data da decisão" />
                                        <Label fx:id="lblDataDecisao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Observações do supervisor" />
                                        <Label fx:id="lblObservacoesSupervisor" styleClass="meta-valor" text="-" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Observações da geração" />
                                <Label fx:id="lblResumoGeracao" styleClass="subtitulo" text="Ainda não existe uma proposta carregada." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalColaboradores" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Colaboradores" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalTurnos" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Turnos gerados" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalDiasCobertos" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Dias cobertos" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox fx:id="painelValidacaoSupervisor" spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Validação do supervisor" />
                        <Label styleClass="subtitulo" text="Revê a proposta mensal selecionada e decide se os horários devem ser publicados ou rejeitados." wrapText="true" />

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Observações da decisão" />
                                <TextArea fx:id="txtObservacoesSupervisor" prefRowCount="3" promptText="Opcional: acrescenta observações para o histórico da decisão." styleClass="campo-textarea" wrapText="true" />
                            </children>
                        </VBox>

                        <Label fx:id="lblFeedbackValidacao" managed="false" visible="false" wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button fx:id="btnRejeitarProposta" onAction="#onRejeitarPropostaClick" styleClass="botao-secundario" text="Rejeitar proposta" />
                                <Button fx:id="btnAprovarProposta" onAction="#onAprovarPropostaClick" styleClass="botao-acao" text="Aprovar e publicar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Label styleClass="subtitulo" text="Distribuição por colaborador" />

                <TableView fx:id="tabelaResumoColaboradores" prefHeight="200.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colResumoColaborador" prefWidth="230.0" text="Colaborador" />
                        <TableColumn fx:id="colResumoCargo" prefWidth="160.0" text="Cargo" />
                        <TableColumn fx:id="colResumoTurnos" prefWidth="120.0" text="Turnos" />
                        <TableColumn fx:id="colResumoHoras" prefWidth="140.0" text="Horas" />
                    </columns>
                </TableView>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="subtitulo" text="Calendário semanal do planeamento" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Filtrar por colaborador" />
                                <ComboBox fx:id="cbFiltroColaborador" prefWidth="260.0" promptText="Toda a equipa" styleClass="campo-combo" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onSemanaPlaneamentoAnteriorClick" styleClass="botao-secundario" text="Semana anterior" />
                                <Label fx:id="lblSemanaPlaneamento" styleClass="campo-titulo" text="Semana" />
                                <Button onAction="#onSemanaPlaneamentoSeguinteClick" styleClass="botao-secundario" text="Semana seguinte" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox fx:id="boxSemanaPlaneamento" spacing="10.0" styleClass="calendario-semana" />
            </children>
        </VBox>
    </content>
</ScrollPane>
