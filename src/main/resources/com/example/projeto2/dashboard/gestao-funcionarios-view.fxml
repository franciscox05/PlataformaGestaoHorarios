<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="conteudo-pagina, modulo-com-abas"
      stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.projeto2.DESKTOP.GestaoFuncionariosController">

    <!-- ░░ CABEÇALHO DE PÁGINA ░░ -->
    <VBox spacing="8.0" styleClass="modulo-banner modulo-banner-card modulo-banner-funcionarios"
          style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #9b1c1c 0%, #450a0a 100%); -fx-background-insets: 0; -fx-background-radius: 16px;">
        <VBox.margin><Insets top="40.0" right="40.0" bottom="24.0" left="40.0" /></VBox.margin>
        <padding><Insets top="26.0" right="30.0" bottom="26.0" left="30.0" /></padding>
        <Label styleClass="modulo-titulo" text="Gest&#227;o de funcion&#225;rios" />
        <Label styleClass="modulo-subtitulo"
               text="Adiciona, atualiza e desativa colaboradores da tua loja sem sair do backoffice."
               wrapText="true" />
    </VBox>

    <!-- ░░ ABAS FOCADAS ░░ -->
    <TabPane styleClass="modulo-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>

            <!-- ═════ ABA 1 — EQUIPA ═════ -->
            <Tab text="Equipa">
                <content>
                    <VBox spacing="20.0" styleClass="aba-conteudo">
                        <padding><Insets top="24.0" right="40.0" bottom="32.0" left="40.0" /></padding>

                        <!-- Contexto da loja -->
                        <HBox spacing="0.0" styleClass="context-bar">
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="LOJA" />
                                <Label fx:id="lblNomeLoja" styleClass="meta-valor" text="-" />
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="LOCALIZA&#199;&#195;O" />
                                <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="PERFIL DE ACESSO" />
                                <Label fx:id="lblCargoGestor" styleClass="meta-valor" text="-" />
                            </VBox>
                        </HBox>

                        <!-- Tabela + Formulário -->
                        <HBox alignment="TOP_LEFT" spacing="20.0" VBox.vgrow="ALWAYS">

                            <!-- TABELA DA EQUIPA -->
                            <VBox spacing="16.0" styleClass="info-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label styleClass="card-titulo" text="Equipa da Loja" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblResumoTabela"
                                           styleClass="meta-etiqueta"
                                           text="0 colaborador(es)" />
                                </HBox>

                                <HBox spacing="10.0">
                                    <TextField fx:id="txtPesquisa"
                                               promptText="Pesquisar por nome, email, telem&#243;vel ou cargo"
                                               styleClass="campo-input"
                                               HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbFiltroEstado" styleClass="campo-combo" />
                                    <ComboBox fx:id="cbFiltroCargo"  styleClass="campo-combo" />
                                </HBox>

                                <Label styleClass="texto-atalho"
                                       text="Enter seleciona o primeiro resultado  &#183;  Esc limpa  &#183;  Ctrl+S guardar  &#183;  Ctrl+N novo colaborador"
                                       wrapText="true" />

                                <TableView fx:id="tabelaColaboradores" VBox.vgrow="ALWAYS" styleClass="tabela-premium">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colNome"      text="Nome" />
                                        <TableColumn fx:id="colEmail"     text="Email" />
                                        <TableColumn fx:id="colTelemovel" text="Telem&#243;vel" />
                                        <TableColumn fx:id="colCargo"     text="Cargo" />
                                        <TableColumn fx:id="colEstado"    text="Estado" />
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- FORMULÁRIO DE COLABORADOR -->
                            <VBox spacing="14.0" styleClass="info-card"
                                  HBox.hgrow="NEVER" minWidth="320.0" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label fx:id="lblTituloFormulario"
                                           styleClass="card-titulo"
                                           text="Novo Colaborador" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#onNovoClick"
                                            styleClass="botao-secundario"
                                            text="Novo" />
                                </HBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="NOME" />
                                    <TextField fx:id="txtNome"
                                               promptText="Nome completo do colaborador"
                                               styleClass="campo-input" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="EMAIL" />
                                    <TextField fx:id="txtEmail"
                                               promptText="email@empresa.pt"
                                               styleClass="campo-input" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="TELEM&#211;VEL" />
                                    <TextField fx:id="txtTelemovel"
                                               promptText="9 d&#237;gitos"
                                               styleClass="campo-input" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="PASSWORD" />
                                    <PasswordField fx:id="txtPassword"
                                                   promptText="Obrigat&#243;ria ao criar; opcional na edi&#231;&#227;o"
                                                   styleClass="campo-input" />
                                    <Label styleClass="texto-ajuda"
                                           text="Na edi&#231;&#227;o, deixa a password vazia para a manter."
                                           wrapText="true" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="CARGO" />
                                    <ComboBox fx:id="cbCargo" maxWidth="Infinity" styleClass="campo-combo" />
                                </VBox>

                                <VBox spacing="5.0">
                                    <Label styleClass="campo-titulo" text="ESTADO" />
                                    <ComboBox fx:id="cbEstado" maxWidth="Infinity" styleClass="campo-combo" />
                                </VBox>

                                <Label fx:id="lblMensagem" managed="false" styleClass="mensagem-feedback"
                                       text="" visible="false" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <Button fx:id="btnDesativar"
                                            onAction="#onDesativarClick"
                                            styleClass="botao-secundario"
                                            text="Desativar" />
                                    <Button fx:id="btnRedefinirPassword"
                                            onAction="#onRedefinirPasswordClick"
                                            disable="true"
                                            styleClass="botao-secundario"
                                            text="Redefinir Password" />
                                    <Button fx:id="btnGuardar"
                                            onAction="#onGuardarClick"
                                            styleClass="botao-acao"
                                            text="Guardar" />
                                </HBox>
                            </VBox>

                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ═════ ABA 2 — PERFIL DO COLABORADOR ═════ -->
            <Tab text="Perfil do colaborador">
                <content>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                styleClass="conteudo-scroll">
                        <content>
                            <VBox spacing="16.0" styleClass="aba-conteudo">
                                <padding><Insets top="24.0" right="40.0" bottom="44.0" left="40.0" /></padding>

                                <!-- ── Barra de contexto: resumo do colaborador + toggle vista + navegação ── -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="context-bar">
                                    <Label fx:id="lblPerfilOperacionalResumo"
                                           styleClass="meta-valor"
                                           text="Seleciona um colaborador na aba Equipa para ver o perfil completo."
                                           wrapText="true"
                                           HBox.hgrow="ALWAYS" />
                                    <Region minWidth="16.0" />
                                    <Button fx:id="btnModoSemanal"
                                            onAction="#onModoSemanalClick"
                                            styleClass="botao-acao"
                                            text="Semana" />
                                    <Button fx:id="btnModoMensal"
                                            onAction="#onModoMensalClick"
                                            styleClass="botao-secundario"
                                            text="M&#234;s" />
                                    <Region minWidth="8.0" />
                                    <Button onAction="#onSemanaColaboradorAnteriorClick"
                                            styleClass="botao-nav" text="&#8249; Anterior" />
                                    <Label fx:id="lblSemanaColaborador"
                                           styleClass="campo-titulo" text="&#8212;" />
                                    <Button onAction="#onSemanaColaboradorSeguinteClick"
                                            styleClass="botao-nav" text="Seguinte &#8250;" />
                                </HBox>

                                <!-- ── Horário do colaborador (full-width) ── -->
                                <VBox spacing="12.0" styleClass="info-card">
                                    <Label styleClass="card-titulo" text="Hor&#225;rio do colaborador" />
                                    <Label fx:id="lblResumoHorarioColaborador"
                                           styleClass="texto-ajuda"
                                           text="Seleciona um colaborador para ver o hor&#225;rio publicado."
                                           wrapText="true" />

                                    <!-- Vista semanal: 7 cards lado a lado -->
                                    <HBox fx:id="boxSemanaColaborador"
                                          spacing="10.0"
                                          styleClass="calendario-semana"
                                          minHeight="160.0" />

                                    <!-- Vista mensal: GridPane (gerido pelo controller) -->
                                    <GridPane fx:id="grelhaHorarioMensalColaborador"
                                              hgap="8.0" vgap="8.0"
                                              managed="false" visible="false" />
                                </VBox>

                                <!-- ── Perfil operacional: Folgas / Preferências / Permutas ── -->
                                <VBox spacing="10.0" styleClass="info-card">
                                    <Label styleClass="card-titulo" text="Perfil operacional" />

                                    <TabPane tabClosingPolicy="UNAVAILABLE"
                                             styleClass="modulo-tabs"
                                             prefHeight="260.0">
                                        <tabs>

                                            <Tab text="Folgas">
                                                <content>
                                                    <TableView fx:id="tabelaFolgasColaborador"
                                                               styleClass="tabela-premium"
                                                               prefHeight="200.0">
                                                        <columnResizePolicy>
                                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                        </columnResizePolicy>
                                                        <columns>
                                                            <TableColumn fx:id="colFolgaData"   text="Data" />
                                                            <TableColumn fx:id="colFolgaTipo"   text="Tipo" />
                                                            <TableColumn fx:id="colFolgaEstado" text="Estado" />
                                                            <TableColumn fx:id="colFolgaAcao"   text="A&#231;&#227;o" />
                                                        </columns>
                                                    </TableView>
                                                </content>
                                            </Tab>

                                            <Tab text="Prefer&#234;ncias">
                                                <content>
                                                    <TableView fx:id="tabelaPreferenciasColaborador"
                                                               styleClass="tabela-premium"
                                                               prefHeight="200.0">
                                                        <columnResizePolicy>
                                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                        </columnResizePolicy>
                                                        <columns>
                                                            <TableColumn fx:id="colPreferenciaTipo"    text="Tipo" />
                                                            <TableColumn fx:id="colPreferenciaPeriodo" text="Per&#237;odo" />
                                                            <TableColumn fx:id="colPreferenciaEstado"  text="Estado" />
                                                            <TableColumn fx:id="colPreferenciaAcao"    text="A&#231;&#227;o" />
                                                        </columns>
                                                    </TableView>
                                                </content>
                                            </Tab>

                                            <Tab text="Permutas">
                                                <content>
                                                    <TableView fx:id="tabelaPermutasColaborador"
                                                               styleClass="tabela-premium"
                                                               prefHeight="200.0">
                                                        <columnResizePolicy>
                                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                        </columnResizePolicy>
                                                        <columns>
                                                            <TableColumn fx:id="colPermutaData"   text="Data turno" />
                                                            <TableColumn fx:id="colPermutaTurnos" text="Troca" />
                                                            <TableColumn fx:id="colPermutaEstado" text="Estado" />
                                                            <TableColumn fx:id="colPermutaAcao"   text="A&#231;&#227;o" />
                                                        </columns>
                                                    </TableView>
                                                </content>
                                            </Tab>

                                        </tabs>
                                    </TabPane>
                                </VBox>

                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>

        </tabs>
    </TabPane>

</VBox>
