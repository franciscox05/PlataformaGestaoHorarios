<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.GestaoLojaController">
    <content>
        <VBox spacing="0" styleClass="conteudo-pagina">

            <!-- ══════════════════════════════════════════════
                 BANNER DE TOPO — LOJA
            ══════════════════════════════════════════════ -->
            <StackPane styleClass="page-banner, page-banner-loja">
                <VBox spacing="6.0" StackPane.alignment="BOTTOM_LEFT">
                    <StackPane.margin>
                        <Insets bottom="36.0" left="40.0" right="40.0" top="40.0" />
                    </StackPane.margin>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="icon-badge-white-lg" minWidth="32.0" minHeight="32.0">
                            <SVGPath fill="rgba(255,255,255,0.85)"
                                     content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                     styleClass="banner-icon-sm" />
                        </StackPane>
                        <Label styleClass="hero-chip" text="&#11044; CONFIGURA&#199;&#195;O DA LOJA" />
                    </HBox>
                    <Label styleClass="page-banner-title" text="Loja e regras" />
                    <Label styleClass="page-banner-subtitle"
                           text="Atualiza o hor&#225;rio da loja, ajusta as regras base do planeamento e define exce&#231;&#245;es por data."
                           wrapText="true" />
                </VBox>
            </StackPane>

            <!-- ══════════════════════════════════════════════
                 CORPO — BENTO LAYOUT
            ══════════════════════════════════════════════ -->
            <VBox spacing="32.0">
                <padding><Insets bottom="48.0" left="40.0" right="40.0" top="40.0" /></padding>

                <!-- BENTO ROW: Contexto + Horário -->
                <HBox spacing="20.0">

                    <!-- Contexto da loja -->
                    <VBox spacing="16.0" styleClass="bento-card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                                <SVGPath fill="#c41230"
                                         content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                         styleClass="card-icon" />
                            </StackPane>
                            <VBox spacing="2.0">
                                <Label styleClass="stat-kicker" text="IDENTIFICA&#199;&#195;O" />
                                <Label styleClass="bento-card-titulo" text="Contexto da loja" />
                            </VBox>
                        </HBox>
                        <Region minHeight="4.0" />
                        <HBox spacing="24.0">
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="Loja" />
                                <Label fx:id="lblNomeLoja" styleClass="meta-valor" text="-" />
                            </VBox>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="Localiza&#231;&#227;o" />
                                <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                            </VBox>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="meta-etiqueta" text="Perfil de acesso" />
                                <Label fx:id="lblCargoGestor" styleClass="meta-valor" text="-" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Horário de funcionamento -->
                <VBox spacing="16.0" styleClass="bento-card, bento-card-destacado" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                                <SVGPath fill="#2563eb"
                                         content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"
                                         styleClass="card-icon" />
                            </StackPane>
                            <VBox spacing="2.0">
                                <Label styleClass="stat-kicker" text="HOR&#193;RIO" />
                                <Label styleClass="bento-card-titulo" text="Funcionamento" />
                            </VBox>
                        </HBox>
                        <Label styleClass="bento-card-subtitulo"
                               text="Indica as horas no formato HH:mm. Se a loja fechar ap&#243;s a meia-noite, o fecho pode ser inferior &#224; abertura."
                               wrapText="true" />
                        <HBox spacing="20.0">
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="campo-titulo" text="Hora de abertura" />
                                <TextField fx:id="txtHoraAbertura" promptText="HH:mm" styleClass="campo-input" />
                            </VBox>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="campo-titulo" text="Hora de fecho" />
                                <TextField fx:id="txtHoraFecho" promptText="HH:mm" styleClass="campo-input" />
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ─── REGRAS ESPECÍFICAS ─── -->
                <VBox spacing="16.0" styleClass="bento-card">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="stat-icon-wrap-orange" minWidth="40.0" minHeight="40.0">
                            <SVGPath fill="#ea580c"
                                     content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                                     styleClass="card-icon" />
                        </StackPane>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="stat-kicker" text="CONFIGURA&#199;&#195;O" />
                            <Label styleClass="bento-card-titulo" text="Regras espec&#237;ficas da loja" />
                        </VBox>
                        <Button onAction="#onGuardarClick" styleClass="botao-acao"
                                text="Guardar configura&#231;&#227;o" />
                    </HBox>
                    <Label fx:id="lblMensagem" managed="false" styleClass="mensagem-feedback"
                           text="" visible="false" wrapText="true" />
                    <VBox fx:id="regrasContainer" spacing="32.0" />
                </VBox>

                <!-- ─── EXCEÇÕES POR DATA ─── -->
                <VBox spacing="16.0" styleClass="bento-card">

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                            <SVGPath fill="#c41230"
                                     content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zm-7-8.5c-2.33 0-7 1.17-7 3.5V17h14v-2c0-2.33-4.67-3.5-7-3.5zm0-1c1.38 0 2.5-1.12 2.5-2.5S13.38 6 12 6 9.5 7.12 9.5 8.5 10.62 11 12 11z"
                                     styleClass="card-icon" />
                        </StackPane>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="stat-kicker" text="CALEND&#193;RIO" />
                            <Label styleClass="bento-card-titulo" text="Hor&#225;rios especiais e exce&#231;&#245;es" />
                        </VBox>
                        <Button onAction="#onLimparHorarioEspecialClick"
                                styleClass="botao-secundario" text="Nova exce&#231;&#227;o" />
                        <Button onAction="#onGuardarHorarioEspecialClick"
                                styleClass="botao-acao" text="Guardar exce&#231;&#227;o" />
                    </HBox>

                    <Label styleClass="bento-card-subtitulo"
                           text="Cria exce&#231;&#245;es para um intervalo de datas: encerra a loja, reduz ou alarga o hor&#225;rio e ajusta o m&#237;nimo por turno."
                           wrapText="true" />

                    <!-- Descrição -->
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="Descri&#231;&#227;o" />
                        <TextField fx:id="txtDescricaoExcecao"
                                   promptText="Ex.: Feriado local ou campanha de fim de semana"
                                   styleClass="campo-input" />
                    </VBox>

                    <!-- Datas + modo -->
                    <HBox spacing="20.0">
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Data inicial" />
                            <DatePicker fx:id="dpDataInicioExcecao" maxWidth="Infinity" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Data final" />
                            <DatePicker fx:id="dpDataFimExcecao" maxWidth="Infinity" />
                        </VBox>
                        <VBox alignment="BOTTOM_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Modo da exce&#231;&#227;o" />
                            <CheckBox fx:id="chkLojaEncerrada" text="Loja encerrada neste per&#237;odo" />
                        </VBox>
                    </HBox>

                    <!-- Horário especial + mínimo -->
                    <HBox spacing="20.0">
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Hora de abertura especial" />
                            <TextField fx:id="txtHoraAberturaExcecao" promptText="HH:mm"
                                       styleClass="campo-input" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Hora de fecho especial" />
                            <TextField fx:id="txtHoraFechoExcecao" promptText="HH:mm"
                                       styleClass="campo-input" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="M&#237;nimo especial por turno" />
                            <TextField fx:id="txtMinimoExcecao" promptText="Opcional: inteiro"
                                       styleClass="campo-input" />
                        </VBox>
                    </HBox>

                    <!-- Observações -->
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="Observa&#231;&#245;es internas" />
                        <TextArea fx:id="txtObservacoesExcecao" prefRowCount="3"
                                  promptText="Notas para contextualizar a exce&#231;&#227;o configurada."
                                  styleClass="campo-textarea" wrapText="true" />
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Button onAction="#onRemoverHorarioEspecialClick"
                                styleClass="botao-secundario" text="Remover selecionada" />
                        <Label styleClass="bento-card-subtitulo"
                               text="Seleciona uma linha da tabela para editar ou remover uma exce&#231;&#227;o existente."
                               wrapText="true" />
                    </HBox>

                    <Label fx:id="lblMensagemExcecao" managed="false"
                           styleClass="mensagem-feedback" text="" visible="false" wrapText="true" />

                    <!-- Empty state -->
                    <VBox fx:id="emptyStateExcecoes" alignment="CENTER" spacing="12.0"
                          styleClass="empty-state-box">
                        <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                        <SVGPath fill="#dddddd"
                                 content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                                 styleClass="empty-state-icon" />
                        <Label styleClass="empty-state-titulo" text="Sem exce&#231;&#245;es definidas" />
                        <Label styleClass="empty-state-subtitulo"
                               text="Cria a primeira exce&#231;&#227;o de hor&#225;rio acima para feriados ou campanhas."
                               wrapText="true" />
                    </VBox>

                    <TableView fx:id="tabelaHorariosEspeciais" styleClass="tabela-premium"
                               VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colPeriodoExcecao"           text="Per&#237;odo" />
                            <TableColumn fx:id="colOperacaoExcecao"          text="Opera&#231;&#227;o" />
                            <TableColumn fx:id="colHorarioExcecao"           text="Hor&#225;rio aplicado" />
                            <TableColumn fx:id="colMinimoExcecao"            text="M&#237;nimo" />
                            <TableColumn fx:id="colDescricaoExcecao"         text="Descri&#231;&#227;o" />
                            <TableColumn fx:id="colTurnosCompativeisExcecao" text="Turnos compat&#237;veis" />
                        </columns>
                    </TableView>

                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
