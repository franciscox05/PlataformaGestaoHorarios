<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.GestaoLojaController">
    <content>
        <VBox alignment="TOP_CENTER" prefWidth="760.0" spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label styleClass="titulo-dashboard" text="Loja e regras" />
                <Label styleClass="subtitulo" text="Atualiza o hor&#225;rio da loja, ajusta as regras base do planeamento e define exce&#231;&#245;es por data para feriados, campanhas ou opera&#231;&#227;o sazonal." wrapText="true" />

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Contexto da loja" />

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Loja" />
                                        <Label fx:id="lblNomeLoja" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Localiza&#231;&#227;o" />
                                        <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Perfil de acesso" />
                                        <Label fx:id="lblCargoGestor" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Hor&#225;rio de funcionamento" />
                        <Label styleClass="subtitulo" text="Indica manualmente as horas no formato HH:mm. Se a loja fechar depois da meia-noite, podes indicar uma hora de fecho inferior &#224; abertura." wrapText="true" />

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Hora de abertura" />
                                        <TextField fx:id="txtHoraAbertura" promptText="HH:mm" styleClass="campo-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Hora de fecho" />
                                        <TextField fx:id="txtHoraFecho" promptText="HH:mm" styleClass="campo-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="card-titulo" text="Regras espec&#237;ficas da loja" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onGuardarClick" styleClass="botao-acao" text="Guardar configura&#231;&#227;o" />
                            </children>
                        </HBox>

                        <Label fx:id="lblMensagem" managed="false" styleClass="mensagem-feedback" text="" visible="false" wrapText="true" />
                        <VBox fx:id="regrasContainer" spacing="14.0" />
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="card-titulo" text="Hor&#225;rios especiais e exce&#231;&#245;es por data" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#onLimparHorarioEspecialClick" styleClass="botao-secundario" text="Nova exce&#231;&#227;o" />
                                <Button onAction="#onGuardarHorarioEspecialClick" styleClass="botao-acao" text="Guardar exce&#231;&#227;o" />
                            </children>
                        </HBox>

                        <Label styleClass="subtitulo" text="Cria exce&#231;&#245;es espec&#237;ficas para um intervalo de datas. Podes encerrar a loja, reduzir ou alargar o hor&#225;rio do dia e ajustar o m&#237;nimo por turno." wrapText="true" />

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Descri&#231;&#227;o" />
                                        <TextField fx:id="txtDescricaoExcecao" promptText="Ex.: Feriado local ou campanha de fim de semana" styleClass="campo-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data inicial" />
                                        <DatePicker fx:id="dpDataInicioExcecao" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data final" />
                                        <DatePicker fx:id="dpDataFimExcecao" />
                                    </children>
                                </VBox>

                                <VBox alignment="BOTTOM_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Modo da exce&#231;&#227;o" />
                                        <CheckBox fx:id="chkLojaEncerrada" text="Loja encerrada neste per&#237;odo" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Hora de abertura especial" />
                                        <TextField fx:id="txtHoraAberturaExcecao" promptText="HH:mm" styleClass="campo-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Hora de fecho especial" />
                                        <TextField fx:id="txtHoraFechoExcecao" promptText="HH:mm" styleClass="campo-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="M&#237;nimo especial por turno" />
                                        <TextField fx:id="txtMinimoExcecao" promptText="Opcional: inteiro" styleClass="campo-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Observa&#231;&#245;es internas" />
                                <TextArea fx:id="txtObservacoesExcecao" prefRowCount="3" promptText="Notas para contextualizar a exce&#231;&#227;o configurada." styleClass="campo-textarea" wrapText="true" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Button onAction="#onRemoverHorarioEspecialClick" styleClass="botao-secundario" text="Remover selecionada" />
                                <Label styleClass="subtitulo" text="Seleciona uma linha da tabela para editar ou remover uma exce&#231;&#227;o existente." wrapText="true" />
                            </children>
                        </HBox>

                        <Label fx:id="lblMensagemExcecao" managed="false" styleClass="mensagem-feedback" text="" visible="false" wrapText="true" />

                        <TableView fx:id="tabelaHorariosEspeciais" prefHeight="240.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colPeriodoExcecao" prefWidth="140.0" text="Per&#237;odo" />
                                <TableColumn fx:id="colOperacaoExcecao" prefWidth="170.0" text="Opera&#231;&#227;o" />
                                <TableColumn fx:id="colHorarioExcecao" prefWidth="170.0" text="Hor&#225;rio aplicado" />
                                <TableColumn fx:id="colMinimoExcecao" prefWidth="120.0" text="M&#237;nimo" />
                                <TableColumn fx:id="colDescricaoExcecao" prefWidth="190.0" text="Descri&#231;&#227;o" />
                                <TableColumn fx:id="colTurnosCompativeisExcecao" prefWidth="230.0" text="Turnos compat&#237;veis" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
