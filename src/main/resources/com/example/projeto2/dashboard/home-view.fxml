<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="760.0" prefWidth="980.0" styleClass="dashboard-scroll" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.HomeController">
    <content>
        <VBox spacing="28.0" styleClass="page-shell">
            <padding>
                <Insets bottom="34.0" left="36.0" right="36.0" top="30.0" />
            </padding>

            <children>
                <Label fx:id="lblBemVindo" styleClass="home-greeting" text="Ol&#225;, equipa!" />

                <StackPane styleClass="editorial-banner">
                    <children>
                        <Region styleClass="editorial-banner-texture" />
                        <VBox maxWidth="620.0" spacing="10.0" styleClass="schedule-hero-copy" StackPane.alignment="BOTTOM_LEFT">
                            <StackPane.margin>
                                <Insets bottom="34.0" left="34.0" />
                            </StackPane.margin>
                            <children>
                                <Label styleClass="hero-chip" text="HOR&#193;RIO PUBLICADO" />
                                <Label styleClass="schedule-hero-title" text="Semana atual" />
                                <Label fx:id="lblResumoHorarioPublicado" styleClass="schedule-hero-description" text="Resumo do hor&#225;rio publicado." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <VBox spacing="14.0">
                    <children>
                        <Label styleClass="section-title" text="Os meus turnos" />

                        <VBox spacing="16.0" styleClass="info-card schedule-table-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label fx:id="lblSemanaHorarioPublicadoIntervalo" styleClass="metric-kicker" text="Semana" />
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label styleClass="campo-titulo" text="Semana de refer&#234;ncia" />
                                                <ComboBox fx:id="cbSemanaHorarioPublicado" prefWidth="260.0" promptText="Selecionar semana" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#onSemanaHorarioAnteriorClick" styleClass="botao-secundario" text="Semana anterior" />
                                        <Button onAction="#onSemanaHorarioSeguinteClick" styleClass="botao-secundario" text="Semana seguinte" />
                                    </children>
                                </HBox>

                                <HBox fx:id="boxSemanaHorarioPublicado" spacing="10.0" styleClass="calendario-semana" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="16.0">
                    <children>
                        <Label styleClass="section-title" text="Atalhos r&#225;pidos" />

                        <HBox spacing="18.0">
                            <children>
                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="FOLGAS E F&#201;RIAS" wrapText="true" />
                                        <Label styleClass="action-card-copy" text="Submete folgas e f&#233;rias, acompanha o estado dos teus pedidos e gere aus&#234;ncias com contexto." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoFolga" onAction="#onAtalhoFolgaClick" styleClass="link-button" text="Abrir pedidos de folga" />
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="PREFER&#202;NCIAS" />
                                        <Label styleClass="action-card-copy" text="Atualiza disponibilidade, colegas preferidos e defini&#231;&#245;es que influenciam o planeamento." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoPreferencias" onAction="#onAtalhoPreferenciasClick" styleClass="link-button" text="Abrir prefer&#234;ncias" />
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="PERFIL" wrapText="true" />
                                        <Label styleClass="action-card-copy" text="Atualiza os teus dados pessoais, refor&#231;a a seguran&#231;a da conta e rev&#234; a informa&#231;&#227;o essencial." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoPerfil" onAction="#onAtalhoPerfilClick" styleClass="link-button" text="Abrir perfil" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox fx:id="painelAcoesGestao" alignment="CENTER_LEFT" managed="false" spacing="10.0" visible="false">
                            <children>
                                <Button fx:id="btnAtalhoPainelGerente" onAction="#onAtalhoPainelGerenteClick" styleClass="botao-acao" text="Pedidos pendentes" />
                                <Button fx:id="btnAtalhoHorarios" onAction="#onAtalhoHorariosClick" styleClass="botao-secundario" text="Gera&#231;&#227;o de hor&#225;rios" />
                                <Button fx:id="btnAtalhoRelatorios" onAction="#onAtalhoRelatoriosClick" styleClass="botao-secundario" text="Relat&#243;rios" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Equipa escalada hoje" />
                        <Label styleClass="texto-ajuda" text="Vis&#227;o r&#225;pida da equipa prevista para hoje na tua loja, com hor&#225;rio e estado resumidos." wrapText="true" />
                        <TableView fx:id="tabelaEquipaHoje" prefHeight="220.0" styleClass="editorial-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colColaboradorHoje" text="Colaborador" />
                                <TableColumn fx:id="colHorarioHoje" text="Hor&#225;rio" />
                                <TableColumn fx:id="colEstadoHoje" text="Estado" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox fx:id="painelOperacaoLoja" managed="false" spacing="18.0" styleClass="info-card operation-card" visible="false">
                    <children>
                        <Label styleClass="section-title" text="Opera&#231;&#227;o da loja" />
                        <Label styleClass="texto-ajuda" text="Consulta a escala publicada da tua loja, filtra por colaborador e ganha contexto operacional sem sair do painel." wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data base" />
                                        <DatePicker fx:id="dpDataOperacao" promptText="Selecionar data" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Intervalo" />
                                        <ComboBox fx:id="cbIntervaloOperacao" prefWidth="150.0" promptText="Seleciona o intervalo" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Colaborador" />
                                        <ComboBox fx:id="cbColaboradorOperacao" prefWidth="270.0" promptText="Filtrar colaborador" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="14.0">
                            <children>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoColaboradores" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Colaboradores previstos" wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoTurnos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Turnos planeados" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoAusencias" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Aus&#234;ncias" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoPedidos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Pedidos pendentes" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="lblResumoOperacao" styleClass="texto-ajuda" text="Resumo operacional indispon&#237;vel." wrapText="true" />
                        <Label fx:id="lblFeedbackOperacao" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />

                        <Label styleClass="card-titulo" text="Resumo por colaborador" />
                        <TableView fx:id="tabelaOperacaoLoja" prefHeight="240.0" styleClass="editorial-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colOperacaoColaborador" text="Colaborador" />
                                <TableColumn fx:id="colOperacaoCargo" text="Cargo" />
                                <TableColumn fx:id="colOperacaoTurnos" text="Turnos no per&#237;odo" />
                                <TableColumn fx:id="colOperacaoEstado" text="Estado" />
                            </columns>
                        </TableView>

                        <Label styleClass="card-titulo" text="Escala publicada da loja" />
                        <Label fx:id="lblResumoEscalaPublicada" styleClass="texto-ajuda" text="A carregar escala publicada..." wrapText="true" />
                        <HBox fx:id="boxEscalaDetalhadaLoja" spacing="10.0" styleClass="calendario-semana" />

                        <VBox spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label styleClass="card-titulo" text="Hor&#225;rio mensal da loja" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="campo-titulo" text="M&#234;s" />
                                                <ComboBox fx:id="cbMesHorarioMensal" prefWidth="170.0" promptText="Seleciona o m&#234;s" styleClass="campo-combo" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="campo-titulo" text="Ano" />
                                                <Spinner fx:id="spAnoHorarioMensal" prefWidth="110.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label fx:id="lblResumoHorarioMensal" styleClass="texto-ajuda" text="A carregar hor&#225;rio mensal da loja..." wrapText="true" />
                                <GridPane fx:id="gridHorarioMensalLoja" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
