<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="760.0" prefWidth="980.0" stylesheets="@dashboard.css" styleClass="dashboard-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.HomeController">
    <content>
        <VBox spacing="28.0" styleClass="page-shell">
            <padding>
                <Insets bottom="34.0" left="36.0" right="36.0" top="30.0" />
            </padding>

            <children>
                <Label fx:id="lblBemVindo" styleClass="home-greeting" text="Ola, equipa!" />

                <StackPane styleClass="editorial-banner">
                    <children>
                        <Region styleClass="editorial-banner-texture" />
                        <VBox maxWidth="620.0" spacing="10.0" styleClass="schedule-hero-copy" StackPane.alignment="BOTTOM_LEFT">
                            <StackPane.margin>
                                <Insets bottom="34.0" left="34.0" />
                            </StackPane.margin>
                            <children>
                                <Label styleClass="hero-chip" text="HORARIO PUBLICADO" />
                                <Label styleClass="schedule-hero-title" text="Semana atual" />
                                <Label fx:id="lblResumoHorarioPublicado" styleClass="schedule-hero-description" text="Resumo do horario publicado." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <VBox spacing="14.0">
                    <children>
                        <Label styleClass="section-title" text="Os meus turnos" />

                        <VBox spacing="16.0" styleClass="info-card schedule-table-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label fx:id="lblSemanaHorarioPublicadoIntervalo" styleClass="metric-kicker" text="Semana" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#onSemanaHorarioAnteriorClick" styleClass="botao-secundario" text="Semana anterior" />
                                        <Button onAction="#onSemanaHorarioSeguinteClick" styleClass="botao-secundario" text="Semana seguinte" />
                                    </children>
                                </HBox>

                                <HBox fx:id="boxSemanaHorarioPublicado" spacing="10.0" styleClass="calendario-semana" />

                                <TableView fx:id="tabelaTurnos" prefHeight="300.0" styleClass="editorial-table">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colData" text="Data" />
                                        <TableColumn fx:id="colHorario" text="Horario" />
                                        <TableColumn fx:id="colLoja" text="Loja / contexto" />
                                        <TableColumn fx:id="colEstado" text="Estado" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="16.0">
                    <children>
                        <Label styleClass="section-title" text="Atalhos rapidos" />

                        <HBox spacing="18.0">
                            <children>
                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="TROCAS DE TURNO" wrapText="true" />
                                        <Label styleClass="action-card-copy" text="Coordena trocas de turno e acompanha o mercado interno da equipa." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoFolga" onAction="#onAtalhoFolgaClick" styleClass="link-button" text="Abrir pedidos de folga" />
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="FOLGAS E FERIAS" />
                                        <Label styleClass="action-card-copy" text="Submete folgas e ve rapidamente o estado dos teus pedidos pendentes ou aprovados." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoPreferencias" onAction="#onAtalhoPreferenciasClick" styleClass="link-button" text="Abrir preferencias" />
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="action-card exact-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="action-card-title" text="PREFERENCIAS" wrapText="true" />
                                        <Label styleClass="action-card-copy" text="Atualiza disponibilidade, colegas preferidos e definicoes que influenciam o planeamento." wrapText="true" />
                                        <Region VBox.vgrow="ALWAYS" />
                                        <Button fx:id="btnAtalhoPerfil" onAction="#onAtalhoPerfilClick" styleClass="link-button" text="Abrir perfil" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox fx:id="painelAcoesGestao" alignment="CENTER_LEFT" managed="false" spacing="10.0" visible="false">
                            <children>
                                <Button fx:id="btnAtalhoPainelGerente" onAction="#onAtalhoPainelGerenteClick" styleClass="botao-acao" text="Pedidos pendentes" />
                                <Button fx:id="btnAtalhoHorarios" onAction="#onAtalhoHorariosClick" styleClass="botao-secundario" text="Geracao de horarios" />
                                <Button fx:id="btnAtalhoRelatorios" onAction="#onAtalhoRelatoriosClick" styleClass="botao-secundario" text="Relatorios" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Equipa escalada hoje" />
                        <Label styleClass="texto-ajuda" text="Visao rapida da equipa prevista para hoje na tua loja, com horario e estado resumidos." wrapText="true" />
                        <TableView fx:id="tabelaEquipaHoje" prefHeight="220.0" styleClass="editorial-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colColaboradorHoje" text="Colaborador" />
                                <TableColumn fx:id="colHorarioHoje" text="Horario" />
                                <TableColumn fx:id="colEstadoHoje" text="Estado" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox fx:id="painelOperacaoLoja" managed="false" spacing="18.0" styleClass="info-card operation-card" visible="false">
                    <children>
                        <Label styleClass="section-title" text="Operacao da loja" />
                        <Label styleClass="texto-ajuda" text="Consulta a escala publicada da tua loja, filtra por colaborador e ganha contexto operacional sem sair do painel." wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data base" />
                                        <DatePicker fx:id="dpDataOperacao" promptText="Selecionar data" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Intervalo" />
                                        <ComboBox fx:id="cbIntervaloOperacao" prefWidth="150.0" promptText="Seleciona o intervalo" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Colaborador" />
                                        <ComboBox fx:id="cbColaboradorOperacao" prefWidth="270.0" promptText="Filtrar colaborador" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="14.0">
                            <children>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoColaboradores" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Colaboradores previstos" wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoTurnos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Turnos planeados" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoAusencias" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Ausencias" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card premium-stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoPedidos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Pedidos pendentes" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="lblResumoOperacao" styleClass="texto-ajuda" text="Resumo operacional indisponivel." wrapText="true" />
                        <Label fx:id="lblFeedbackOperacao" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />

                        <Label styleClass="card-titulo" text="Resumo por colaborador" />
                        <TableView fx:id="tabelaOperacaoLoja" prefHeight="240.0" styleClass="editorial-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colOperacaoColaborador" text="Colaborador" />
                                <TableColumn fx:id="colOperacaoCargo" text="Cargo" />
                                <TableColumn fx:id="colOperacaoTurnos" text="Turnos no periodo" />
                                <TableColumn fx:id="colOperacaoEstado" text="Estado" />
                            </columns>
                        </TableView>

                        <Label styleClass="card-titulo" text="Escala publicada da loja" />
                        <Label fx:id="lblResumoEscalaPublicada" styleClass="texto-ajuda" text="A carregar escala publicada..." wrapText="true" />
                        <TableView fx:id="tabelaEscalaDetalhada" prefHeight="260.0" styleClass="editorial-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colEscalaData" text="Data" />
                                <TableColumn fx:id="colEscalaColaborador" text="Colaborador" />
                                <TableColumn fx:id="colEscalaCargo" text="Cargo" />
                                <TableColumn fx:id="colEscalaHorario" text="Horario" />
                                <TableColumn fx:id="colEscalaEstado" text="Estado" />
                            </columns>
                        </TableView>

                        <VBox spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label styleClass="card-titulo" text="Horario mensal da loja" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="campo-titulo" text="Mes" />
                                                <ComboBox fx:id="cbMesHorarioMensal" prefWidth="170.0" promptText="Seleciona o mes" styleClass="campo-combo" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="campo-titulo" text="Ano" />
                                                <Spinner fx:id="spAnoHorarioMensal" prefWidth="110.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label fx:id="lblResumoHorarioMensal" styleClass="texto-ajuda" text="A carregar horario mensal da loja..." wrapText="true" />

                                <TableView fx:id="tabelaHorarioMensalLoja" prefHeight="320.0" styleClass="editorial-table tabela-mensal-loja">
                                    <columnResizePolicy>
                                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
