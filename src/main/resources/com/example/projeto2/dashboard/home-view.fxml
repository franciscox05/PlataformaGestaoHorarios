<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="600.0" prefWidth="730.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.HomeController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label fx:id="lblBemVindo" styleClass="titulo-dashboard" text="Bem-vindo ao Dashboard!" />
                <Label styleClass="subtitulo" text="Os teus proximos turnos, a equipa da tua loja hoje e o contexto diario da operacao." wrapText="true" />

                <VBox spacing="10.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Acoes Rapidas" />
                        <Label styleClass="texto-ajuda" text="Usa estes atalhos para saltares diretamente para a proxima acao util, sem andares a navegar pelo menu lateral." wrapText="true" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="btnAtalhoFolga" onAction="#onAtalhoFolgaClick" styleClass="botao-acao" text="Pedir folga" />
                                <Button fx:id="btnAtalhoPreferencias" onAction="#onAtalhoPreferenciasClick" styleClass="botao-secundario" text="Preferencias" />
                                <Button fx:id="btnAtalhoPerfil" onAction="#onAtalhoPerfilClick" styleClass="botao-secundario" text="Perfil" />
                            </children>
                        </HBox>
                        <HBox fx:id="painelAcoesGestao" alignment="CENTER_LEFT" managed="false" spacing="10.0" visible="false">
                            <children>
                                <Button fx:id="btnAtalhoPainelGerente" onAction="#onAtalhoPainelGerenteClick" styleClass="botao-secundario" text="Pedidos pendentes" />
                                <Button fx:id="btnAtalhoHorarios" onAction="#onAtalhoHorariosClick" styleClass="botao-secundario" text="Geracao de horarios" />
                                <Button fx:id="btnAtalhoRelatorios" onAction="#onAtalhoRelatoriosClick" styleClass="botao-secundario" text="Relatorios" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="TOP_CENTER" spacing="20.0">
                    <children>
                        <VBox spacing="10.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="subtitulo" text="Proximos turnos" />
                                <Label styleClass="texto-ajuda" text="Consulta aqui os teus proximos turnos confirmados e acompanha rapidamente o estado atual de cada um." wrapText="true" />
                                <TableView fx:id="tabelaTurnos" prefHeight="260.0">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colData" prefWidth="120.0" text="Data" />
                                        <TableColumn fx:id="colHorario" prefWidth="150.0" text="Horario" />
                                        <TableColumn fx:id="colLoja" prefWidth="250.0" text="Loja" />
                                        <TableColumn fx:id="colEstado" prefWidth="150.0" text="Estado" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox prefWidth="280.0" spacing="10.0" styleClass="info-card">
                            <children>
                                <Label styleClass="subtitulo" text="Equipa de Hoje" />
                                <Label styleClass="texto-ajuda" text="Ve quem esta escalado hoje contigo na tua loja, com horario e estado resumidos." wrapText="true" />
                                <TableView fx:id="tabelaEquipaHoje" prefHeight="260.0" prefWidth="280.0">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colColaboradorHoje" prefWidth="130.0" text="Colaborador" />
                                        <TableColumn fx:id="colHorarioHoje" prefWidth="90.0" text="Horario" />
                                        <TableColumn fx:id="colEstadoHoje" prefWidth="80.0" text="Estado" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox fx:id="painelOperacaoLoja" managed="false" spacing="16.0" styleClass="info-card" visible="false">
                    <children>
                        <Label styleClass="card-titulo" text="Painel Diario da Loja" />
                        <Label styleClass="texto-ajuda" text="Consulta rapidamente a escala da tua loja num dia ou intervalo curto, sem saires do dashboard." wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data base" />
                                        <DatePicker fx:id="dpDataOperacao" promptText="Selecionar data" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Intervalo" />
                                        <ComboBox fx:id="cbIntervaloOperacao" prefWidth="140.0" promptText="Seleciona o intervalo" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoColaboradores" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Colaboradores previstos" wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoTurnos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Turnos planeados" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoAusencias" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Ausencias" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblOperacaoPedidos" styleClass="stat-numero" text="0" />
                                        <Label styleClass="stat-titulo" text="Pedidos pendentes" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="lblResumoOperacao" styleClass="texto-ajuda" text="Resumo operacional indisponivel." wrapText="true" />
                        <Label fx:id="lblFeedbackOperacao" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />

                        <TableView fx:id="tabelaOperacaoLoja" prefHeight="240.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colOperacaoColaborador" text="Colaborador" />
                                <TableColumn fx:id="colOperacaoCargo" text="Cargo" />
                                <TableColumn fx:id="colOperacaoTurnos" text="Turnos no periodo" />
                                <TableColumn fx:id="colOperacaoEstado" text="Estado" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
