<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll, modulo-home"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.DESKTOP.HomeController">
    <content>
        <VBox spacing="20.0" styleClass="conteudo-pagina, home-dashboard-pro">
            <padding>
                <Insets top="24.0" right="36.0" bottom="48.0" left="36.0" />
            </padding>

            <!-- ░░ HERO COMPACTO — saudação + filtros de turno ░░ -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="home-hero-inline">
                <padding>
                    <Insets top="20.0" right="28.0" bottom="20.0" left="28.0" />
                </padding>
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblBemVindo" styleClass="home-inline-title" text="Bom dia, Equipa." />
                    <Label fx:id="lblResumoHorarioPublicado"
                           styleClass="home-inline-copy"
                           text="Resumo operacional da loja para hoje."
                           wrapText="true" />
                </VBox>
                <HBox alignment="CENTER" spacing="6.0">
                    <Button fx:id="pillTodos"  onAction="#onPillTodosClick"  styleClass="home-filter-pill-active" text="Todos" />
                    <Button fx:id="pillManha"  onAction="#onPillManhaClick"  styleClass="home-filter-pill"        text="Manhã" />
                    <Button fx:id="pillTarde"  onAction="#onPillTardeClick"  styleClass="home-filter-pill"        text="Tarde" />
                    <Button fx:id="pillNoite"  onAction="#onPillNoiteClick"  styleClass="home-filter-pill"        text="Noite" />
                </HBox>
                <Label fx:id="lblDataHoje" styleClass="home-date-chip" text="Hoje" />
            </HBox>

            <!-- ░░ BANNER PENDENTES (só gestão) ░░ -->
            <HBox fx:id="bannerPendentes"
                  alignment="CENTER_LEFT"
                  managed="false"
                  spacing="14.0"
                  styleClass="home-banner-pendentes"
                  visible="false">
                <padding>
                    <Insets top="14.0" right="20.0" bottom="14.0" left="20.0" />
                </padding>
                <FontIcon iconLiteral="mdi2a-alert-circle-outline" iconSize="18" styleClass="home-banner-pendentes-icon" />
                <Label fx:id="lblBannerPendentes"
                       styleClass="home-banner-pendentes-texto"
                       text="Tens pedidos pendentes a aguardar aprovação."
                       HBox.hgrow="ALWAYS" />
                <Button fx:id="btnBannerVerPedidos"
                        onAction="#onBannerVerPedidosClick"
                        styleClass="home-banner-pendentes-btn"
                        text="Ver pedidos" />
            </HBox>

            <!-- ░░ HORÁRIO SEMANAL — HERO PRINCIPAL, full-width ░░ -->
            <VBox spacing="16.0" styleClass="home-schedule-hero">
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <StackPane styleClass="home-section-icon">
                        <FontIcon iconLiteral="mdi2c-calendar-month" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="home-card-title" text="Horário Semanal" />
                        <Label fx:id="lblSemanaHorarioPublicadoIntervalo"
                               styleClass="home-card-subtitle"
                               text="Semana atual" />
                    </VBox>
                    <ComboBox fx:id="cbSemanaHorarioPublicado"
                              prefWidth="230.0"
                              promptText="Selecionar semana"
                              styleClass="home-week-select" />
                    <Button onAction="#onSemanaHorarioAnteriorClick" styleClass="home-arrow-btn" text="&#8249;" />
                    <Button onAction="#onSemanaHorarioSeguinteClick" styleClass="home-arrow-btn" text="&#8250;" />
                </HBox>

                <HBox fx:id="boxSemanaHorarioPublicado"
                      minHeight="230.0"
                      spacing="10.0"
                      styleClass="home-week-strip" />
            </VBox>

            <!-- ░░ HORÁRIO MENSAL DA EQUIPA — calendário + grelha (gestão) ░░ -->
            <VBox fx:id="secaoGrelhaEquipaMensal"
                  managed="false"
                  spacing="16.0"
                  styleClass="home-panel-card"
                  visible="false">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <StackPane styleClass="home-section-icon">
                        <FontIcon iconLiteral="mdi2c-calendar-month" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="home-card-title" text="Hor&#225;rio Mensal da Equipa" />
                        <Label styleClass="home-card-subtitle"
                               text="Escala publicada de toda a loja."
                               wrapText="true" />
                    </VBox>
                    <!-- Toggle Vista -->
                    <HBox alignment="CENTER" spacing="4.0" styleClass="home-vista-toggle">
                        <Button fx:id="btnVistaCalendarioHome"
                                onAction="#onVistaCalendarioHomeClick"
                                styleClass="home-vista-btn-active"
                                text="Calend&#225;rio" />
                        <Button fx:id="btnVistaGrelhaHome"
                                onAction="#onVistaGrelhaHomeClick"
                                styleClass="home-vista-btn"
                                text="Grelha" />
                    </HBox>
                </HBox>

                <HBox alignment="BOTTOM_LEFT" spacing="12.0">
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="M&#234;s" />
                        <ComboBox fx:id="cbMesHorarioMensal" prefWidth="170.0" promptText="Seleciona o m&#234;s" styleClass="campo-combo" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="Ano" />
                        <Spinner fx:id="spAnoHorarioMensal" prefWidth="110.0" />
                    </VBox>
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="campo-titulo" text="Colaborador" />
                        <ComboBox fx:id="cbColaboradorHorarioMensal" maxWidth="Infinity" promptText="Toda a equipa" styleClass="campo-combo" />
                    </VBox>
                </HBox>

                <Label fx:id="lblResumoHorarioMensal"
                       styleClass="home-card-subtitle"
                       text="A carregar hor&#225;rio mensal da loja..."
                       wrapText="true" />

                <!-- Vista Calendário (GridPane mensal) -->
                <VBox fx:id="painelVistaCalendarioHome" spacing="8.0">
                    <GridPane fx:id="calendarioMensalHome"
                              hgap="8.0"
                              vgap="8.0"
                              styleClass="calendario-mensal-grid" />
                </VBox>

                <!-- Vista Grelha (linhas colaborador × dias) -->
                <ScrollPane fx:id="scrollGrelhaEquipaMensal"
                            fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="NEVER"
                            managed="false"
                            minHeight="260.0"
                            styleClass="grelha-scroll"
                            visible="false">
                    <content>
                        <VBox fx:id="boxGrelhaEquipaMensal" styleClass="grelha-container" />
                    </content>
                </ScrollPane>
            </VBox>

            <!-- ░░ EQUIPA EM LOJA HOJE + PRÓXIMOS TURNOS ░░ -->
            <HBox spacing="20.0" alignment="TOP_LEFT">

                <!-- Equipa em loja hoje -->
                <VBox spacing="16.0" styleClass="home-panel-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="home-section-icon">
                            <FontIcon iconLiteral="mdi2a-account-group" iconSize="18" />
                        </StackPane>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="home-card-title" text="Equipa em Loja Agora" />
                            <Label styleClass="home-card-subtitle" text="Presença prevista para hoje" />
                        </VBox>
                        <Label fx:id="lblChipEscala" styleClass="home-chip-ok" text="Escala publicada" />
                        <Button fx:id="btnAprovarHorarioHome"
                                managed="false"
                                onAction="#onAprovarHorarioClick"
                                styleClass="home-chip-button"
                                text="Aprovar Hor&#225;rio"
                                visible="false" />
                    </HBox>

                    <TableView fx:id="tabelaEquipaHoje"
                               prefHeight="240.0"
                               styleClass="home-table"
                               VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colColaboradorHoje" text="Colaborador" />
                            <TableColumn fx:id="colHorarioHoje"     text="Hor&#225;rio" />
                            <TableColumn fx:id="colEstadoHoje"      text="Estado" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- Coluna direita: Próximos turnos + Pedidos pendentes -->
                <VBox spacing="20.0" minWidth="320.0" prefWidth="350.0">

                <!-- Próximos Turnos + Ações rápidas -->
                <VBox spacing="16.0" styleClass="home-dark-card">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="home-dark-title" text="Pr&#243;ximos Turnos" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onAtalhoHorariosClick" styleClass="home-dark-arrow" text="&#8594;" />
                    </HBox>
                    <Label fx:id="lblProximoTurnoInfo"
                           styleClass="home-dark-copy"
                           text="A carregar informa&#231;&#245;es dos teus pr&#243;ximos turnos..."
                           wrapText="true" />
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="home-quick-actions">
                        <Button fx:id="btnAtalhoFolga"
                                onAction="#onAtalhoFolgaClick"
                                styleClass="home-chip-button"
                                text="Pedir folga" />
                        <Button fx:id="btnAtalhoPreferencias"
                                onAction="#onAtalhoPreferenciasClick"
                                styleClass="home-chip-button, home-chip-button-dark"
                                text="Prefer&#234;ncias" />
                    </HBox>
                    <Button fx:id="btnAtalhoPerfil"
                            onAction="#onAtalhoPerfilClick"
                            maxWidth="Infinity"
                            styleClass="home-dark-outline"
                            text="Abrir o meu perfil" />

                    <Region prefHeight="2.0" />

                    <!-- Ações de gestão -->
                    <HBox fx:id="painelAcoesGestao"
                          alignment="CENTER_LEFT"
                          managed="false"
                          spacing="10.0"
                          visible="false">
                        <Button fx:id="btnAtalhoPainelGerente"
                                onAction="#onAtalhoPainelGerenteClick"
                                styleClass="home-chip-button"
                                text="Pedidos" />
                        <Button fx:id="btnAtalhoHorarios"
                                onAction="#onAtalhoHorariosClick"
                                styleClass="home-chip-button, home-chip-button-dark"
                                text="Hor&#225;rios" />
                        <Button fx:id="btnAtalhoRelatorios"
                                onAction="#onAtalhoRelatoriosClick"
                                styleClass="home-chip-button, home-chip-button-dark"
                                text="Relat&#243;rios" />
                    </HBox>

                    <!-- Métricas inline (só gestão) -->
                    <VBox fx:id="painelMetricasLoja"
                          managed="false"
                          spacing="14.0"
                          visible="false">
                        <Label styleClass="home-metrics-title" text="M&#233;tricas da Loja" />
                        <Label styleClass="home-card-subtitle"
                               text="Indicadores alimentados pela escala e pedidos reais."
                               wrapText="true" />

                        <GridPane hgap="10.0" vgap="10.0">
                            <VBox spacing="4.0" styleClass="home-metric-tile" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="home-metric-label" text="Colaboradores" />
                                <Label fx:id="lblOperacaoColaboradores" styleClass="home-metric-value" text="-" />
                            </VBox>
                            <VBox spacing="4.0" styleClass="home-metric-tile" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="home-metric-label" text="Turnos" />
                                <Label fx:id="lblOperacaoTurnos" styleClass="home-metric-value" text="-" />
                            </VBox>
                            <VBox spacing="4.0" styleClass="home-metric-tile" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="home-metric-label" text="Aus&#234;ncias" />
                                <Label fx:id="lblOperacaoAusencias" styleClass="home-metric-value" text="-" />
                            </VBox>
                            <VBox spacing="4.0" styleClass="home-metric-tile" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="home-metric-label" text="Pedidos" />
                                <Label fx:id="lblOperacaoPedidos" styleClass="home-metric-value" text="-" />
                            </VBox>
                        </GridPane>

                        <Button onAction="#onAtalhoHorariosClick"
                                maxWidth="Infinity"
                                styleClass="home-black-action"
                                text="Gerir aloca&#231;&#245;es" />
                    </VBox>
                </VBox>

                <!-- Pedidos pendentes (gestão) — aprovar/rejeitar inline -->
                <VBox fx:id="painelPedidosPendentes"
                      managed="false"
                      spacing="14.0"
                      styleClass="home-panel-card"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="home-section-icon">
                            <FontIcon iconLiteral="mdi2c-clipboard-list-outline" iconSize="18" />
                        </StackPane>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="home-card-title" text="Pedidos pendentes" />
                            <Label fx:id="lblPedidosPendentesSub"
                                   styleClass="home-card-subtitle"
                                   text="0 por decidir" />
                        </VBox>
                        <Button fx:id="btnVerTodosPedidos"
                                onAction="#onAtalhoPainelGerenteClick"
                                styleClass="home-chip-button"
                                text="Ver todos" />
                    </HBox>
                    <VBox fx:id="listaPedidosPendentes" spacing="8.0" />
                </VBox>
                </VBox>
            </HBox>

            <!-- ░░ OS MEUS PEDIDOS (colaboradores) ░░ -->
            <VBox fx:id="painelMeusPedidos"
                  managed="false"
                  spacing="12.0"
                  styleClass="home-panel-card"
                  visible="false">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <StackPane styleClass="home-section-icon">
                        <FontIcon iconLiteral="mdi2c-clipboard-list-outline" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="home-card-title" text="Os Meus Pedidos" />
                        <Label styleClass="home-card-subtitle" text="Estado dos teus &#250;ltimos pedidos de folga e troca de turno" />
                    </VBox>
                    <Button onAction="#onAtalhoFolgaClick"
                            styleClass="home-chip-button"
                            text="Novo pedido" />
                </HBox>
                <VBox fx:id="listaMeusPedidos" spacing="6.0" />
            </VBox>

            <!-- ░░ OPERAÇÃO DA LOJA (gestão) ░░ -->
            <VBox fx:id="painelOperacaoLoja"
                  managed="false"
                  spacing="18.0"
                  styleClass="home-panel-card, home-manager-panel"
                  visible="false">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <StackPane styleClass="home-section-icon">
                        <FontIcon iconLiteral="mdi2v-view-dashboard" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="home-card-title" text="Opera&#231;&#227;o da Loja" />
                        <Label fx:id="lblResumoOperacao"
                               styleClass="home-card-subtitle"
                               text="Resumo operacional indispon&#237;vel."
                               wrapText="true" />
                    </VBox>
                </HBox>

                <HBox spacing="12.0">
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="Data base" />
                        <DatePicker fx:id="dpDataOperacao" promptText="Selecionar data" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label styleClass="campo-titulo" text="Intervalo" />
                        <ComboBox fx:id="cbIntervaloOperacao" prefWidth="170.0" promptText="Seleciona o intervalo" />
                    </VBox>
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="campo-titulo" text="Colaborador" />
                        <ComboBox fx:id="cbColaboradorOperacao" maxWidth="Infinity" promptText="Filtrar colaborador" />
                    </VBox>
                </HBox>

                <Label fx:id="lblFeedbackOperacao"
                       managed="false"
                       styleClass="mensagem-feedback"
                       text="Mensagem"
                       visible="false"
                       wrapText="true" />

                <TableView fx:id="tabelaOperacaoLoja" prefHeight="220.0" styleClass="home-table">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colOperacaoColaborador" text="Colaborador" />
                        <TableColumn fx:id="colOperacaoCargo"       text="Cargo" />
                        <TableColumn fx:id="colOperacaoTurnos"      text="Turnos no per&#237;odo" />
                        <TableColumn fx:id="colOperacaoEstado"      text="Estado" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Label styleClass="home-card-title" text="Escala publicada da loja" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="4.0" styleClass="home-vista-toggle">
                        <Button fx:id="btnVistaStripEscala"
                                onAction="#onVistaStripEscalaClick"
                                styleClass="home-vista-btn-active"
                                text="Semana" />
                        <Button fx:id="btnVistaGrelhaEscala"
                                onAction="#onVistaGrelhaEscalaClick"
                                styleClass="home-vista-btn"
                                text="Grelha" />
                    </HBox>
                </HBox>
                <Label fx:id="lblResumoEscalaPublicada"
                       styleClass="home-card-subtitle"
                       text="Escala publicada indispon&#237;vel."
                       wrapText="true" />
                <!-- Vista Semana: strip de 7 cartões diários (default) -->
                <HBox fx:id="boxEscalaDetalhadaLoja"
                      minHeight="150.0"
                      spacing="10.0"
                      styleClass="home-week-strip" />
                <!-- Vista Grelha: colaboradores × dias da semana -->
                <ScrollPane fx:id="scrollGrelhaEscalaLoja"
                            fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="NEVER"
                            managed="false"
                            minHeight="260.0"
                            styleClass="grelha-scroll"
                            visible="false">
                    <content>
                        <VBox fx:id="boxGrelhaEscalaLoja" styleClass="grelha-container" />
                    </content>
                </ScrollPane>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
