<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll, modulo-auditoria"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.PainelAuditoriaController">
    <content>
        <VBox spacing="0" styleClass="conteudo-pagina">

            <HBox managed="false" visible="false">
                <Label fx:id="lblLoja" text="-" />
                <Label fx:id="lblLocalizacao" text="-" />
                <Label fx:id="lblCargo" text="-" />
            </HBox>

            <VBox spacing="32.0">
                <padding>
                    <Insets bottom="48.0" left="40.0" right="40.0" top="40.0" />
                </padding>

                <VBox spacing="8.0" styleClass="modulo-banner modulo-banner-card modulo-banner-auditoria"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #9b1c1c 0%, #450a0a 100%); -fx-background-insets: 0; -fx-background-radius: 16px;">
                    <padding><Insets bottom="26.0" left="30.0" right="30.0" top="26.0" /></padding>
                    <Label styleClass="modulo-titulo" text="Auditoria e seguran&#231;a" />
                    <Label styleClass="modulo-subtitulo"
                           text="Consulta o registo de eventos, autentica&#231;&#245;es e altera&#231;&#245;es sens&#237;veis da tua loja."
                           wrapText="true" />
                </VBox>

                <VBox spacing="16.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath fill="#c91428"
                                 content="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"
                                 styleClass="section-icon" />
                        <Label styleClass="section-title" text="Resumo de Eventos" />
                    </HBox>
                    <HBox spacing="16.0">
                    <VBox alignment="CENTER" spacing="12.0"
                          styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-blue" minWidth="48.0" minHeight="48.0">
                                <SVGPath fill="#2563eb"
                                         content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"
                                         styleClass="stat-icon" />
                            </StackPane>
                            <Label fx:id="lblTotalEventos" styleClass="stat-numero" text="0" />
                            <Label styleClass="stat-titulo" text="Eventos totais" />
                        </VBox>
                    <VBox alignment="CENTER" spacing="12.0"
                          styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-red" minWidth="48.0" minHeight="48.0">
                                <SVGPath fill="#c91428"
                                         content="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                         styleClass="stat-icon" />
                            </StackPane>
                            <Label fx:id="lblTotalFalhas" styleClass="stat-numero" text="0" />
                            <Label styleClass="stat-titulo" text="Falhas registadas" />
                        </VBox>
                    <VBox alignment="CENTER" spacing="12.0"
                          styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-green" minWidth="48.0" minHeight="48.0">
                                <SVGPath fill="#16a34a"
                                         content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                         styleClass="stat-icon" />
                            </StackPane>
                            <Label fx:id="lblTotalAutenticacoes" styleClass="stat-numero" text="0" />
                            <Label styleClass="stat-titulo" text="Autentica&#231;&#245;es" />
                        </VBox>
                    <VBox alignment="CENTER" spacing="12.0"
                          styleClass="bento-card, premium-stat-card" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-orange" minWidth="48.0" minHeight="48.0">
                                <SVGPath fill="#ea580c"
                                         content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                         styleClass="stat-icon" />
                            </StackPane>
                            <Label fx:id="lblTotalAlteracoes" styleClass="stat-numero" text="0" />
                            <Label styleClass="stat-titulo" text="Altera&#231;&#245;es sens&#237;veis" />
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="20.0" styleClass="bento-card">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                            <SVGPath fill="#2563eb"
                                     content="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"
                                     styleClass="card-icon" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label styleClass="stat-kicker" text="PESQUISA" />
                            <Label styleClass="bento-card-titulo" text="Filtros de Pesquisa" />
                            <Label styleClass="bento-card-subtitulo"
                                   text="Sem datas definidas mostra os eventos mais recentes" />
                        </VBox>
                    </HBox>

                    <GridPane hgap="20.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="30.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="30.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="20.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="20.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Tipo de evento" />
                            <ComboBox fx:id="cbTipoEvento" maxWidth="Infinity" styleClass="campo-combo" />
                        </VBox>

                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Colaborador" />
                            <ComboBox fx:id="cbColaborador" maxWidth="Infinity" styleClass="campo-combo" />
                        </VBox>

                        <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Data in&#237;cio" />
                            <DatePicker fx:id="dpDataInicio" promptText="In&#237;cio" maxWidth="Infinity" />
                        </VBox>

                        <VBox spacing="8.0" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Data fim" />
                            <DatePicker fx:id="dpDataFim" promptText="Fim" maxWidth="Infinity" />
                        </VBox>
                    </GridPane>

                    <HBox alignment="CENTER_RIGHT" spacing="12.0">
                        <Label fx:id="lblFeedback" managed="false" styleClass="mensagem-feedback"
                               text="Mensagem" visible="false" wrapText="true" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnLimparFiltros"  onAction="#onLimparFiltrosClick"
                                styleClass="botao-secundario" text="Limpar filtros" />
                        <Button fx:id="btnAplicarFiltros" onAction="#onAplicarFiltrosClick"
                                styleClass="botao-acao" text="Aplicar filtros" />
                    </HBox>
                </VBox>

                <VBox spacing="16.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath fill="#c91428"
                                 content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"
                                 styleClass="section-icon" />
                        <Label styleClass="section-title" text="Hist&#243;rico de Eventos" />
                    </HBox>

                    <VBox styleClass="bento-card" spacing="0">
                        <TableView fx:id="tabelaEventos" VBox.vgrow="ALWAYS" minHeight="280.0"
                                   styleClass="tabela-premium">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDataHora"    text="Data e hora"   minWidth="130.0" />
                                <TableColumn fx:id="colTipo"        text="Tipo"          minWidth="110.0" />
                                <TableColumn fx:id="colResultado"   text="Resultado"     minWidth="90.0" />
                                <TableColumn fx:id="colColaborador" text="Colaborador"   minWidth="130.0" />
                                <TableColumn fx:id="colOrigem"      text="Origem"        minWidth="100.0" />
                                <TableColumn fx:id="colDetalhes"    text="Detalhes" />
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="12.0">
                                    <padding>
                                        <Insets top="48.0" bottom="48.0" left="24.0" right="24.0" />
                                    </padding>
                                    <SVGPath fill="#dddddd"
                                             content="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"
                                             styleClass="empty-state-icon" />
                                    <Label styleClass="empty-state-titulo" text="Sem eventos registados" />
                                    <Label styleClass="empty-state-subtitulo"
                                           text="Nenhum evento corresponde aos filtros selecionados. Tenta ajustar os crit&#233;rios de pesquisa."
                                           textAlignment="CENTER" wrapText="true" maxWidth="340.0" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

                <VBox spacing="20.0" styleClass="bento-card">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="stat-icon-wrap-blue" minWidth="40.0" minHeight="40.0">
                            <SVGPath fill="#2563eb"
                                     content="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"
                                     styleClass="card-icon" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label styleClass="stat-kicker" text="INSPEC&#199;&#195;O" />
                            <Label styleClass="bento-card-titulo" text="Detalhe do Evento Selecionado" />
                            <Label styleClass="bento-card-subtitulo" text="Clica numa linha da tabela acima" />
                        </VBox>
                    </HBox>

                    <GridPane hgap="24.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        </columnConstraints>

                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="meta-etiqueta" text="Colaborador" />
                            <Label fx:id="lblEventoSelecionado" styleClass="meta-valor" text="-" wrapText="true" />
                        </VBox>
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label styleClass="meta-etiqueta" text="Email" />
                            <Label fx:id="lblEmailSelecionado" styleClass="meta-valor" text="-" wrapText="true" />
                        </VBox>
                        <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label styleClass="meta-etiqueta" text="Sess&#227;o" />
                            <Label fx:id="lblSessaoSelecionada" styleClass="meta-valor" text="-" wrapText="true" />
                        </VBox>
                        <VBox spacing="4.0" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label styleClass="meta-etiqueta" text="Momento" />
                            <Label fx:id="lblMomentoSelecionado" styleClass="meta-valor" text="-" wrapText="true" />
                        </VBox>
                    </GridPane>

                    <VBox spacing="8.0">
                        <Label styleClass="campo-titulo" text="Detalhes completos" />
                        <TextArea fx:id="txtDetalhesEvento" styleClass="campo-textarea"
                                  wrapText="true" prefRowCount="5" editable="false" />
                    </VBox>
                </VBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
