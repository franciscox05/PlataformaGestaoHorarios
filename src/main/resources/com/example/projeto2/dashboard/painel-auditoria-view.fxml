<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefHeight="600.0" prefWidth="730.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.PainelAuditoriaController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label styleClass="titulo-dashboard" text="Painel de Auditoria e Seguranca" />
                <Label styleClass="subtitulo" text="Consulta os eventos relevantes da plataforma, filtra por colaborador e periodo e acompanha o historico de autenticacao e alteracoes sensiveis." wrapText="true" />

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Contexto da Loja" />
                        <HBox spacing="30.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Loja" />
                                        <Label fx:id="lblLoja" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Localizacao" />
                                        <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Perfil de acesso" />
                                        <Label fx:id="lblCargo" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalEventos" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Eventos" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalFalhas" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Falhas" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalAutenticacoes" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Autenticacao" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalAlteracoes" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Alteracoes" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Filtros" />
                        <Label styleClass="texto-ajuda" text="Sem datas definidas, o painel mostra os eventos mais recentes associados a tua loja." wrapText="true" />
                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Tipo de evento" />
                                        <ComboBox fx:id="cbTipoEvento" maxWidth="1.7976931348623157E308" styleClass="campo-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Colaborador" />
                                        <ComboBox fx:id="cbColaborador" maxWidth="1.7976931348623157E308" styleClass="campo-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data inicio" />
                                        <DatePicker fx:id="dpDataInicio" promptText="Inicio" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="Data fim" />
                                        <DatePicker fx:id="dpDataFim" promptText="Fim" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnLimparFiltros" onAction="#onLimparFiltrosClick" styleClass="botao-secundario" text="Limpar filtros" />
                                <Button fx:id="btnAplicarFiltros" onAction="#onAplicarFiltrosClick" styleClass="botao-acao" text="Aplicar filtros" />
                            </children>
                        </HBox>
                        <Label fx:id="lblFeedback" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Historico de Eventos" />
                        <TableView fx:id="tabelaEventos" prefHeight="280.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDataHora" text="Data e hora" />
                                <TableColumn fx:id="colTipo" text="Tipo" />
                                <TableColumn fx:id="colResultado" text="Resultado" />
                                <TableColumn fx:id="colColaborador" text="Colaborador" />
                                <TableColumn fx:id="colOrigem" text="Origem" />
                                <TableColumn fx:id="colDetalhes" text="Detalhes" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Detalhe do Evento Selecionado" />
                        <HBox spacing="30.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Colaborador" />
                                        <Label fx:id="lblEventoSelecionado" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Email" />
                                        <Label fx:id="lblEmailSelecionado" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Sessao" />
                                        <Label fx:id="lblSessaoSelecionada" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Momento" />
                                        <Label fx:id="lblMomentoSelecionado" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Detalhes completos" />
                                <TextArea fx:id="txtDetalhesEvento" styleClass="campo-textarea" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
