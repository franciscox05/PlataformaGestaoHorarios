<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefHeight="600.0" prefWidth="730.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.PainelGerentePedidosController">
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label styleClass="titulo-dashboard" text="Painel de Gestao de Pedidos" />
                <Label styleClass="subtitulo" text="Decide num unico ecra os pedidos pendentes de folgas, permutas e preferencias da tua loja." wrapText="true" />

                <VBox spacing="14.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Contexto da Loja" />
                        <HBox spacing="30.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Loja" />
                                        <Label fx:id="lblLoja" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Localizacao" />
                                        <Label fx:id="lblLocalizacao" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-etiqueta" text="Perfil de gestao" />
                                        <Label fx:id="lblCargo" styleClass="meta-valor" text="-" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalPendentes" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Total pendente" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalFolgas" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Folgas" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalPermutas" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Permutas" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTotalPreferencias" styleClass="stat-numero" text="0" />
                                <Label styleClass="stat-titulo" text="Preferencias" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Folgas Pendentes" />
                        <Label styleClass="texto-ajuda" text="Analisa os pedidos de ausencia da loja e decide de imediato os casos pendentes." wrapText="true" />
                        <TableView fx:id="tabelaFolgasPendentes" prefHeight="180.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colFolgaColaborador" text="Colaborador" />
                                <TableColumn fx:id="colFolgaData" text="Data" />
                                <TableColumn fx:id="colFolgaTipo" text="Tipo" />
                                <TableColumn fx:id="colFolgaMotivo" text="Motivo" />
                            </columns>
                        </TableView>
                        <Label fx:id="lblFeedbackFolgas" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnRejeitarFolga" onAction="#onRejeitarFolgaClick" styleClass="botao-secundario" text="Rejeitar" />
                                <Button fx:id="btnAprovarFolga" onAction="#onAprovarFolgaClick" styleClass="botao-acao" text="Aprovar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Permutas Pendentes" />
                        <Label styleClass="texto-ajuda" text="Reve as trocas de turno entre colaboradores e decide a aprovacao diretamente neste painel." wrapText="true" />
                        <TableView fx:id="tabelaPermutasPendentes" prefHeight="200.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colPermutaColaborador" text="Solicitante" />
                                <TableColumn fx:id="colPermutaPedido" text="Pedido" />
                                <TableColumn fx:id="colPermutaOrigem" text="Turno origem" />
                                <TableColumn fx:id="colPermutaDestino" text="Turno destino" />
                            </columns>
                        </TableView>
                        <Label fx:id="lblFeedbackPermutas" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnRejeitarPermuta" onAction="#onRejeitarPermutaClick" styleClass="botao-secundario" text="Rejeitar" />
                                <Button fx:id="btnAprovarPermuta" onAction="#onAprovarPermutaClick" styleClass="botao-acao" text="Aprovar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Preferencias Pendentes" />
                        <Label styleClass="texto-ajuda" text="Fecha a decisao das preferencias da loja antes da geracao e validacao do horario." wrapText="true" />
                        <TableView fx:id="tabelaPreferenciasPendentes" prefHeight="220.0">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colPreferenciaColaborador" text="Colaborador" />
                                <TableColumn fx:id="colPreferenciaTipo" text="Tipo" />
                                <TableColumn fx:id="colPreferenciaPeriodo" text="Periodo" />
                                <TableColumn fx:id="colPreferenciaPrioridade" text="Prioridade" />
                                <TableColumn fx:id="colPreferenciaDescricao" text="Descricao" />
                            </columns>
                        </TableView>
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Observacao da decisao" />
                                <TextArea fx:id="txtDecisaoPreferencia" promptText="Opcional: indica o contexto da aprovacao ou rejeicao." styleClass="campo-textarea" wrapText="true" />
                            </children>
                        </VBox>
                        <Label fx:id="lblFeedbackPreferencias" managed="false" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnRejeitarPreferencia" onAction="#onRejeitarPreferenciaClick" styleClass="botao-secundario" text="Rejeitar" />
                                <Button fx:id="btnAprovarPreferencia" onAction="#onAprovarPreferenciaClick" styleClass="botao-acao" text="Aprovar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
