<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.PedirFolgaController">
    <content>
        <VBox spacing="0" styleClass="conteudo-pagina">

            <!-- ═══════════════════════════════════════════════════
                 BANNER HERO — Pedidos de Ausência (page-banner premium)
            ════════════════════════════════════════════════════ -->
            <VBox spacing="8.0" styleClass="modulo-banner modulo-banner-card modulo-banner-folga"
                  style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #9b1c1c 0%, #450a0a 100%); -fx-background-insets: 0; -fx-background-radius: 16px;">
                <VBox.margin><Insets top="40.0" right="40.0" bottom="24.0" left="40.0" /></VBox.margin>
                <padding><Insets bottom="26.0" left="30.0" right="30.0" top="26.0" /></padding>
                <Label styleClass="modulo-titulo" text="Pedidos de Aus&#234;ncia" />
                <Label styleClass="modulo-subtitulo"
                       text="Regista um novo pedido e acompanha o estado dos anteriores."
                       wrapText="true" />
            </VBox>

            <!-- ═══════════════════════════════════════════════════
                 CORPO — BENTO LAYOUT
            ════════════════════════════════════════════════════ -->
            <VBox spacing="32.0">
                <padding>
                    <Insets bottom="48.0" left="40.0" right="40.0" top="40.0" />
                </padding>

                <!-- ─── FORMULÁRIO NOVO PEDIDO ─── -->
                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath fill="#c91428"
                                 content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                 styleClass="section-icon" />
                        <Label styleClass="section-title" text="Novo Pedido" />
                    </HBox>
                    <Region minHeight="16.0" />
                </VBox>

                <VBox spacing="24.0" styleClass="bento-card">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane styleClass="stat-icon-wrap-red" minWidth="40.0" minHeight="40.0">
                            <SVGPath fill="#c91428"
                                     content="M13 10V3L4 14h7v7l9-11h-7z"
                                     styleClass="card-icon" />
                        </StackPane>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="stat-kicker" text="SUBMISS&#195;O" />
                            <Label styleClass="bento-card-titulo" text="Registar aus&#234;ncia" />
                            <Label styleClass="bento-card-subtitulo"
                                   text="Preenche os campos abaixo e submete o pedido para aprecia&#231;&#227;o do gestor." />
                        </VBox>
                    </HBox>

                    <!-- Data + Tipo em grid -->
                    <GridPane hgap="20.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Data da aus&#234;ncia" />
                            <DatePicker fx:id="dpData" promptText="Selecionar data"
                                        maxWidth="Infinity" />
                        </VBox>

                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label styleClass="campo-titulo" text="Tipo de aus&#234;ncia" />
                            <ComboBox fx:id="cbTipo" promptText="Selecionar tipo"
                                      maxWidth="Infinity" />
                        </VBox>
                    </GridPane>

                    <VBox spacing="8.0">
                        <Label styleClass="campo-titulo" text="Justifica&#231;&#227;o (opcional)" />
                        <TextArea fx:id="txtMotivo"
                                  prefRowCount="4"
                                  promptText="Descreve o motivo do pedido..."
                                  wrapText="true" styleClass="campo-textarea" />
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#onSubmitClick" styleClass="botao-acao"
                                text="Submeter pedido" />
                    </HBox>
                </VBox>

                <!-- ─── HISTÓRICO PESSOAL ─── -->
                <VBox spacing="16.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath fill="#c91428"
                                 content="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                                 styleClass="section-icon" />
                        <Label styleClass="section-title" text="O Meu Hist&#243;rico" />
                    </HBox>

                    <VBox spacing="0" styleClass="bento-card" VBox.vgrow="ALWAYS">
                        <TableView fx:id="tabelaPedidos" VBox.vgrow="ALWAYS" minHeight="200.0"
                                   styleClass="tabela-premium">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDataPedido"   text="Data" />
                                <TableColumn fx:id="colTipoPedido"   text="Tipo" />
                                <TableColumn fx:id="colMotivoPedido" text="Justifica&#231;&#227;o" />
                                <TableColumn fx:id="colEstadoPedido" text="Estado" />
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="12.0">
                                    <padding>
                                        <Insets top="40.0" bottom="40.0" left="24.0" right="24.0" />
                                    </padding>
                                    <SVGPath fill="#dddddd"
                                             content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"
                                             styleClass="empty-state-icon" />
                                    <Label styleClass="empty-state-titulo" text="Nenhum pedido encontrado" />
                                    <Label styleClass="empty-state-subtitulo"
                                           text="Os teus pedidos de aus&#234;ncia aparecer&#227;o aqui depois de os submeteres."
                                           textAlignment="CENTER" wrapText="true" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

                <!-- ─── PAINEL DE APROVAÇÃO (visível apenas para gestores) ─── -->
                <VBox fx:id="painelAprovacao" spacing="16.0">

                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath fill="#ea580c"
                                 content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                 styleClass="section-icon" />
                        <Label styleClass="section-title" text="Aprovar Pedidos da Loja" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="hero-chip" text="&#11044; GESTOR" />
                    </HBox>

                    <VBox spacing="16.0" styleClass="bento-card">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <StackPane styleClass="stat-icon-wrap-orange" minWidth="40.0" minHeight="40.0">
                                <SVGPath fill="#ea580c"
                                         content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                         styleClass="card-icon" />
                            </StackPane>
                            <VBox spacing="2.0">
                                <Label styleClass="stat-kicker" text="APRECIA&#199;&#195;O" />
                                <Label styleClass="bento-card-titulo" text="Pedidos pendentes da loja" />
                                <Label styleClass="bento-card-subtitulo"
                                       text="Seleciona um pedido e aprova ou rejeita." />
                            </VBox>
                        </HBox>

                        <TableView fx:id="tabelaPedidosPendentes" VBox.vgrow="ALWAYS" minHeight="180.0"
                                   styleClass="tabela-premium">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colColaboradorPendente" text="Colaborador" />
                                <TableColumn fx:id="colDataPendente"        text="Data" />
                                <TableColumn fx:id="colTipoPendente"        text="Tipo" />
                                <TableColumn fx:id="colMotivoPendente"      text="Justifica&#231;&#227;o" />
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="12.0">
                                    <padding>
                                        <Insets top="32.0" bottom="32.0" left="24.0" right="24.0" />
                                    </padding>
                                    <SVGPath fill="#dddddd"
                                             content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                             styleClass="empty-state-icon" />
                                    <Label styleClass="empty-state-titulo" text="Nenhum pedido pendente" />
                                    <Label styleClass="empty-state-subtitulo"
                                           text="Todos os pedidos da tua loja est&#227;o tratados."
                                           textAlignment="CENTER" wrapText="true" />
                                </VBox>
                            </placeholder>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <Button fx:id="btnRejeitarPedido" onAction="#onRejeitarPedidoClick"
                                    styleClass="botao-secundario" text="Rejeitar" />
                            <Button fx:id="btnAprovarPedido"  onAction="#onAprovarPedidoClick"
                                    styleClass="botao-acao" text="Aprovar" />
                        </HBox>
                    </VBox>
                </VBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
