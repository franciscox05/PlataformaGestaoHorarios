<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.Controller.PerfilController">
    <content>
        <VBox fx:id="raizPerfil" fillWidth="true" spacing="0" styleClass="conteudo-pagina">

            <StackPane styleClass="page-banner perfil-banner" minHeight="200.0"
                       style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #c91428 0%, #7f0010 100%); -fx-background-insets: 0; -fx-background-radius: 0;">
                <VBox alignment="CENTER" spacing="16.0">
                    <StackPane styleClass="avatar-circle perfil-avatar-circle" prefWidth="96.0" prefHeight="96.0">
                        <Circle radius="48.0" styleClass="avatar-bg"
                                style="-fx-fill: rgba(255,255,255,0.22); -fx-stroke: rgba(255,255,255,0.35); -fx-stroke-width: 2;" />
                        <Label fx:id="lblPerfilAvatar" styleClass="avatar-inicial perfil-avatar-inicial" text="?"
                               style="-fx-text-fill: #ffffff; -fx-font-size: 36px; -fx-font-weight: 700;" />
                    </StackPane>
                    <VBox alignment="CENTER" spacing="6.0">
                        <Label styleClass="banner-titulo" text="O Meu Perfil"
                               style="-fx-text-fill: #ffffff;" />
                        <Label styleClass="banner-subtitulo"
                               text="Dados pessoais · V&#237;nculo ativo · Indicadores do m&#234;s"
                               textAlignment="CENTER" wrapText="true"
                               style="-fx-text-fill: rgba(255,255,255,0.78);" />
                    </VBox>
                </VBox>
            </StackPane>

            <VBox spacing="32.0">
                <padding>
                    <Insets bottom="48.0" left="40.0" right="40.0" top="40.0" />
                </padding>

                <GridPane hgap="24.0" vgap="24.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="55.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="45.0" />
                    </columnConstraints>

                    <VBox spacing="20.0" styleClass="bento-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <StackPane styleClass="icon-badge-blue" prefWidth="40.0" prefHeight="40.0">
                                <SVGPath styleClass="icon-svg-white"
                                         content="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"
                                         scaleX="0.9" scaleY="0.9" />
                            </StackPane>
                            <VBox spacing="2.0">
                                <Label styleClass="bento-card-titulo" text="Dados Pessoais" />
                                <Label styleClass="bento-card-subtitulo" text="Informa&#231;&#227;o da conta" />
                            </VBox>
                        </HBox>

                        <Region styleClass="card-divider" maxHeight="1.0" maxWidth="Infinity" />

                        <GridPane hgap="16.0" vgap="16.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="90.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <Label styleClass="meta-etiqueta" text="Nome" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblNomePerfil" styleClass="meta-valor" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label styleClass="meta-etiqueta" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="lblEmailPerfil" styleClass="meta-valor" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label styleClass="meta-etiqueta" text="Telem&#243;vel" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <Label fx:id="lblTelemovelPerfil" styleClass="meta-valor" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            <Label styleClass="meta-etiqueta" text="Estado" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <Label fx:id="lblEstadoPerfil" styleClass="meta-valor" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        </GridPane>

                        <Region VBox.vgrow="ALWAYS" />

                        <FlowPane hgap="10.0" vgap="10.0">
                            <Button onAction="#onEditarNomeClick"      styleClass="botao-acao-sm" text="&#9998;  Nome" />
                            <Button onAction="#onEditarEmailClick"     styleClass="botao-acao-sm" text="&#9998;  Email" />
                            <Button onAction="#onEditarTelemovelClick" styleClass="botao-acao-sm" text="&#9998;  Telem&#243;vel" />
                            <Button onAction="#onAlterarPasswordClick" styleClass="botao-danger-sm" text="&#128274;  Password" />
                        </FlowPane>
                    </VBox>

                    <VBox spacing="20.0" styleClass="bento-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <StackPane styleClass="icon-badge-red" prefWidth="40.0" prefHeight="40.0">
                                <SVGPath styleClass="icon-svg-white"
                                         content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
                                         scaleX="0.9" scaleY="0.9" />
                            </StackPane>
                            <VBox spacing="2.0">
                                <Label styleClass="bento-card-titulo" text="V&#237;nculo Atual" />
                                <Label styleClass="bento-card-subtitulo" text="Loja e cargo ativos" />
                            </VBox>
                        </HBox>

                        <Region styleClass="card-divider" maxHeight="1.0" maxWidth="Infinity" />

                        <GridPane hgap="16.0" vgap="16.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="110.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <Label styleClass="meta-etiqueta" text="Loja" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblLojaAtual" styleClass="meta-valor" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label styleClass="meta-etiqueta" text="Cargo" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="lblCargoAtual" styleClass="meta-valor" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label styleClass="meta-etiqueta" text="Entrada" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <Label fx:id="lblDataEntrada" styleClass="meta-valor" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            <Label styleClass="meta-etiqueta" text="Pr&#243;x. turno" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <Label fx:id="lblProximoTurno" styleClass="meta-valor-destaque" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        </GridPane>

                        <Region VBox.vgrow="ALWAYS" />

                        <HBox>
                            <StackPane styleClass="badge-ativo">
                                <Label styleClass="badge-texto" text="COLABORADOR ATIVO" />
                            </StackPane>
                        </HBox>
                    </VBox>
                </GridPane>

                <VBox spacing="12.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <SVGPath styleClass="section-icon-accent"
                                 content="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" />
                        <Label styleClass="section-heading" text="Indicadores do M&#234;s" />
                    </HBox>

                    <HBox spacing="20.0">
                        <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card-premium" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-blue" prefWidth="48.0" prefHeight="48.0">
                                <SVGPath styleClass="icon-svg-blue"
                                         content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" />
                            </StackPane>
                            <Label fx:id="lblHorasMes" styleClass="stat-numero-xl" text="0h 0m" />
                            <Label styleClass="stat-titulo" text="Horas este m&#234;s" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card-premium" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-orange" prefWidth="48.0" prefHeight="48.0">
                                <SVGPath styleClass="icon-svg-orange"
                                         content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                            </StackPane>
                            <Label fx:id="lblFolgasPendentes" styleClass="stat-numero-xl" text="0" />
                            <Label styleClass="stat-titulo" text="Folgas pendentes" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card-premium" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-green" prefWidth="48.0" prefHeight="48.0">
                                <SVGPath styleClass="icon-svg-green"
                                         content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                            </StackPane>
                            <Label fx:id="lblFolgasAprovadas" styleClass="stat-numero-xl" text="0" />
                            <Label styleClass="stat-titulo" text="Folgas aprovadas" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card-premium" HBox.hgrow="ALWAYS">
                            <StackPane styleClass="stat-icon-wrap-red" prefWidth="48.0" prefHeight="48.0">
                                <SVGPath styleClass="icon-svg-red"
                                         content="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z" />
                            </StackPane>
                            <Label fx:id="lblTurnosFuturos" styleClass="stat-numero-xl" text="0" />
                            <Label styleClass="stat-titulo" text="Turnos futuros" />
                        </VBox>
                    </HBox>
                </VBox>

                <HBox spacing="20.0" styleClass="bento-card-accent" alignment="CENTER_LEFT">
                    <StackPane styleClass="icon-badge-neutral" prefWidth="44.0" prefHeight="44.0">
                        <SVGPath styleClass="icon-svg-white"
                                 content="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"
                                 scaleX="0.85" scaleY="0.85" />
                    </StackPane>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="bento-card-titulo" text="Sobre este painel" />
                        <Label styleClass="texto-ajuda"
                               text="Este painel re&#250;ne a tua informa&#231;&#227;o pessoal, o teu v&#237;nculo ativo com a loja e os indicadores chave do m&#234;s atual — tudo numa leitura r&#225;pida e centralizada."
                               wrapText="true" />
                    </VBox>
                </HBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
