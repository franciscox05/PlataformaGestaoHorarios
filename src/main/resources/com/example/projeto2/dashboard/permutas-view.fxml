<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.PermutasController">
    <content>
        <VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="730.0" spacing="20.0">

            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label styleClass="titulo-dashboard" text="Trocar turno" />
                <Label styleClass="subtitulo" text="Escolhe um dos teus turnos, seleciona uma opção elegível e acompanha o histórico dos teus pedidos." />

                <HBox alignment="TOP_CENTER" spacing="20.0">
                    <children>
                        <VBox prefWidth="420.0" spacing="15.0" styleClass="info-card">
                            <children>
                                <Label styleClass="card-titulo" text="Novo pedido de permuta" />

                                <VBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="1. O teu turno a ceder" />
                                        <ComboBox fx:id="cbMeuTurno" maxWidth="1.7976931348623157E308" promptText="Escolhe um dos teus turnos futuros" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="2. Colega eleg&#237;vel" />
                                        <ComboBox fx:id="cbColegaElegivel" maxWidth="1.7976931348623157E308" promptText="Escolhe um colega eleg&#237;vel" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="campo-titulo" text="3. Hor&#225;rio pretendido" />
                                        <ComboBox fx:id="cbTurnoColega" maxWidth="1.7976931348623157E308" promptText="Escolhe um turno eleg&#237;vel para troca" />
                                        <Label fx:id="lblTurnosElegiveis" styleClass="texto-apoio" text="Seleciona primeiro um dos teus turnos." wrapText="true" />
                                    </children>
                                </VBox>

                                <Label fx:id="lblMensagem" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />

                                <Button fx:id="btnSubmeterTroca" maxWidth="1.7976931348623157E308" onAction="#onSubmeterTrocaClick" styleClass="botao-acao" text="Submeter pedido de troca" />
                            </children>
                        </VBox>

                        <VBox prefWidth="280.0" spacing="10.0" styleClass="info-card">
                            <children>
                                <Label styleClass="card-titulo" text="Regras rápidas" />
                                <Label styleClass="subtitulo" wrapText="true" text="Os turnos elegíveis são filtrados para a mesma data e loja do teu turno selecionado." />
                                <Label styleClass="subtitulo" wrapText="true" text="Turnos envolvidos numa permuta pendente deixam de aparecer noutras trocas para evitar conflitos." />
                                <Label styleClass="subtitulo" wrapText="true" text="Gestores podem aprovar ou rejeitar pedidos pendentes da sua loja diretamente neste ecrã." />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="subtitulo" text="Histórico de pedidos enviados" />
                        <TableView fx:id="tabelaPedidosPermuta" prefHeight="220.0" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDataPedido" prefWidth="140.0" text="Pedido em" />
                                <TableColumn fx:id="colTurnoOrigem" prefWidth="180.0" text="Meu turno" />
                                <TableColumn fx:id="colTurnoDestino" prefWidth="280.0" text="Turno pretendido" />
                                <TableColumn fx:id="colEstadoPermuta" prefWidth="120.0" text="Estado" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox fx:id="painelAprovacao" managed="false" spacing="12.0" styleClass="info-card" visible="false" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="card-titulo" text="Aprovar pedidos de permuta" />
                        <Label styleClass="subtitulo" text="Pedidos pendentes da tua loja que podem ser tratados por um responsável." wrapText="true" />

                        <TableView fx:id="tabelaPedidosPendentes" prefHeight="240.0" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colColaboradorPendente" prefWidth="150.0" text="Colaborador" />
                                <TableColumn fx:id="colPedidoPendente" prefWidth="140.0" text="Pedido em" />
                                <TableColumn fx:id="colOrigemPendente" prefWidth="160.0" text="Turno atual" />
                                <TableColumn fx:id="colDestinoPendente" prefWidth="240.0" text="Turno pretendido" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnRejeitarPermuta" onAction="#onRejeitarPermutaClick" styleClass="botao-secundario" text="Rejeitar" />
                                <Button fx:id="btnAprovarPermuta" onAction="#onAprovarPermutaClick" styleClass="botao-acao" text="Aprovar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
