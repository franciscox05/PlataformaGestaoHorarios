<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="730.0" spacing="20.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.PermutasController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label styleClass="titulo-dashboard" text="Trocar Turno" />
        <Label styleClass="subtitulo" text="Escolhe um dos teus turnos, seleciona uma opcao elegivel e acompanha o historico dos teus pedidos." />

        <HBox alignment="TOP_CENTER" spacing="20.0">
            <children>
                <VBox prefWidth="420.0" spacing="15.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Novo Pedido de Permuta" />

                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="campo-titulo" text="1. O teu turno a ceder" />
                                <ComboBox fx:id="cbMeuTurno" maxWidth="1.7976931348623157E308" promptText="Escolhe um dos teus turnos futuros" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="campo-titulo" text="2. Turno do colega" />
                                <ComboBox fx:id="cbTurnoColega" maxWidth="1.7976931348623157E308" promptText="Escolhe um turno elegivel para troca" />
                            </children>
                        </VBox>

                        <Label fx:id="lblMensagem" styleClass="mensagem-feedback" text="Mensagem" visible="false" wrapText="true" />

                        <Button maxWidth="1.7976931348623157E308" onAction="#onSubmeterTrocaClick" styleClass="botao-acao" text="Submeter Pedido de Troca" />
                    </children>
                </VBox>

                <VBox prefWidth="280.0" spacing="10.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-titulo" text="Regras Rapidas" />
                        <Label styleClass="subtitulo" wrapText="true" text="Os turnos elegiveis sao filtrados para a mesma data e loja do teu turno selecionado." />
                        <Label styleClass="subtitulo" wrapText="true" text="Nao e possivel pedir permuta do mesmo turno nem repetir um pedido pendente ja existente." />
                        <Label styleClass="subtitulo" wrapText="true" text="O historico abaixo mostra os pedidos enviados por ti e o estado atual de cada um." />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label styleClass="subtitulo" text="Historico de pedidos enviados" />
                <TableView fx:id="tabelaPedidosPermuta" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colDataPedido" prefWidth="140.0" text="Pedido em" />
                        <TableColumn fx:id="colTurnoOrigem" prefWidth="180.0" text="Turno a ceder" />
                        <TableColumn fx:id="colTurnoDestino" prefWidth="280.0" text="Turno pretendido" />
                        <TableColumn fx:id="colEstadoPermuta" prefWidth="120.0" text="Estado" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>

</VBox>
