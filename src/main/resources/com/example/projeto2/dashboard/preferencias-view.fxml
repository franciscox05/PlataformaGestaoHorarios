<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="730.0" spacing="18.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.PreferenciasController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label styleClass="titulo-dashboard" text="As Minhas Preferencias" />
        <Label styleClass="subtitulo" text="Regista as tuas preferencias de folgas, ferias, colegas e turnos para apoiar o planeamento futuro." wrapText="true" />

        <VBox fx:id="painelFormulario" spacing="12.0" styleClass="info-card">
            <children>
                <Label fx:id="lblTituloFormulario" styleClass="card-titulo" text="Nova Preferencia" />

                <HBox spacing="12.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="campo-titulo" text="Tipo de preferencia" />
                                <ComboBox fx:id="cbTipo" promptText="Seleciona o tipo" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Prioridade" />
                                <Spinner fx:id="spPrioridade" prefWidth="110.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="12.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="campo-titulo" text="Data inicial" />
                                <DatePicker fx:id="dpDataInicio" promptText="Selecionar data" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="campo-titulo" text="Data final" />
                                <DatePicker fx:id="dpDataFim" promptText="Opcional" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="campo-titulo" text="Descricao" />
                        <TextArea fx:id="txtDescricao" prefRowCount="4" promptText="Explica a tua preferencia com detalhe suficiente para ser analisada." wrapText="true" />
                    </children>
                </VBox>

                <Label fx:id="lblFeedback" managed="false" visible="false" />

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Button fx:id="btnGuardarPreferencia" onAction="#onGuardarPreferenciaClick" styleClass="botao-acao" text="Guardar Preferencia" />
                        <Button fx:id="btnCancelarEdicao" disable="true" onAction="#onCancelarEdicaoClick" styleClass="botao-secundario" text="Cancelar Edicao" />
                        <Button fx:id="btnRemoverPreferencia" onAction="#onRemoverPreferenciaClick" styleClass="botao-secundario" text="Remover Selecionada" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Label styleClass="subtitulo" text="Historico das tuas preferencias" />

        <TableView fx:id="tabelaPreferencias" prefHeight="220.0" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colTipo" prefWidth="120.0" text="Tipo" />
                <TableColumn fx:id="colPeriodo" prefWidth="180.0" text="Periodo" />
                <TableColumn fx:id="colPrioridade" prefWidth="90.0" text="Prioridade" />
                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
                <TableColumn fx:id="colDescricao" prefWidth="340.0" text="Descricao" />
            </columns>
        </TableView>
    </children>
</VBox>
