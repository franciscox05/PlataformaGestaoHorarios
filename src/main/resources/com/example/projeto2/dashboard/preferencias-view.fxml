<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="conteudo-scroll"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projeto2.DESKTOP.PreferenciasController">
    <content>
        <VBox spacing="0" styleClass="conteudo-pagina">
            <padding>
                <Insets bottom="48.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <VBox spacing="6.0">
                <Label styleClass="titulo-dashboard" text="Prefer&#234;ncias" />
                <Label styleClass="subtitulo"
                       text="Regista as tuas prefer&#234;ncias e, se tiveres perfil de gest&#227;o, decide as prefer&#234;ncias pendentes da tua loja."
                       wrapText="true" />
            </VBox>

            <Region minHeight="24.0" />

            <HBox alignment="TOP_LEFT" spacing="16.0">
                <VBox fx:id="painelFormulario" spacing="14.0" styleClass="bento-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTituloFormulario" styleClass="card-titulo" text="Nova Prefer&#234;ncia" />

                    <VBox spacing="5.0">
                        <Label styleClass="campo-titulo" text="Tipo de prefer&#234;ncia" />
                        <ComboBox fx:id="cbTipo" maxWidth="Infinity" promptText="Seleciona o tipo" styleClass="campo-combo" />
                    </VBox>

                    <VBox fx:id="painelColega" managed="false" spacing="5.0" visible="false">
                        <Label styleClass="campo-titulo" text="Colega preferido" />
                        <ComboBox fx:id="cbColegaPreferido" maxWidth="Infinity" promptText="Seleciona um colega" styleClass="campo-combo" />
                    </VBox>

                    <VBox fx:id="painelTurnos" managed="false" spacing="10.0" styleClass="bento-card-accent" visible="false">
                        <Label styleClass="campo-titulo" text="Prefer&#234;ncia estruturada de turnos" />
                        <Label styleClass="texto-ajuda"
                               text="Escolhe os blocos de turno que preferes para o gerador respeitar melhor o teu pedido mensal."
                               wrapText="true" />
                        <HBox spacing="16.0">
                            <CheckBox fx:id="chkTurnoManha" mnemonicParsing="false" text="Manh&#227; / abertura" />
                            <CheckBox fx:id="chkTurnoIntermedio" mnemonicParsing="false" text="Interm&#233;dio / tarde" />
                            <CheckBox fx:id="chkTurnoNoite" mnemonicParsing="false" text="Noite / fecho" />
                        </HBox>
                        <VBox spacing="5.0">
                            <Label styleClass="campo-titulo" text="Dura&#231;&#227;o preferida" />
                            <ComboBox fx:id="cbDuracaoPreferida" maxWidth="Infinity" promptText="Indiferente" styleClass="campo-combo" />
                        </VBox>
                    </VBox>

                    <HBox spacing="12.0">
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Data inicial" />
                            <DatePicker fx:id="dpDataInicio" maxWidth="Infinity" promptText="Selecionar data" styleClass="campo-input" />
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="campo-titulo" text="Data final" />
                            <DatePicker fx:id="dpDataFim" maxWidth="Infinity" promptText="Opcional" styleClass="campo-input" />
                        </VBox>
                    </HBox>

                    <CheckBox fx:id="chkSemDataFim" mnemonicParsing="false" text="Aplica-se em perman&#234;ncia" />

                    <VBox spacing="5.0">
                        <Label styleClass="campo-titulo" text="Contexto adicional" />
                        <TextArea fx:id="txtDescricao" prefRowCount="4"
                                  promptText="Explica a tua prefer&#234;ncia com detalhe suficiente para ser analisada."
                                  wrapText="true" />
                    </VBox>

                    <Label fx:id="lblFeedback" managed="false" visible="false" wrapText="true" styleClass="mensagem-feedback" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button fx:id="btnGuardarPreferencia" onAction="#onGuardarPreferenciaClick"
                                styleClass="botao-acao" text="Guardar prefer&#234;ncia" />
                        <Button fx:id="btnCancelarEdicao" disable="true" onAction="#onCancelarEdicaoClick"
                                styleClass="botao-secundario" text="Cancelar edi&#231;&#227;o" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnRemoverPreferencia" onAction="#onRemoverPreferenciaClick"
                                styleClass="botao-secundario" text="Remover selecionada" />
                    </HBox>
                </VBox>

                <VBox spacing="10.0" styleClass="bento-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-titulo" text="As minhas prefer&#234;ncias" />
                    <Label styleClass="subtitulo" text="Hist&#243;rico das prefer&#234;ncias que registaste." />
                    <TableView fx:id="tabelaPreferencias" VBox.vgrow="ALWAYS" styleClass="tabela-premium">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colTipo" text="Tipo" />
                            <TableColumn fx:id="colPeriodo" text="Per&#237;odo" />
                            <TableColumn fx:id="colPrioridade" text="Vig&#234;ncia" />
                            <TableColumn fx:id="colEstado" text="Estado" />
                            <TableColumn fx:id="colDescricao" text="Descri&#231;&#227;o" />
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <Region minHeight="20.0" />

            <VBox fx:id="painelAprovacao" spacing="14.0" styleClass="bento-card">
                <Label styleClass="card-titulo" text="Painel de Aprova&#231;&#227;o" />
                <Label styleClass="subtitulo"
                       text="Analisa as prefer&#234;ncias pendentes da tua loja e regista a decis&#227;o antes da gera&#231;&#227;o do hor&#225;rio."
                       wrapText="true" />

                <TableView fx:id="tabelaPreferenciasPendentes" VBox.vgrow="ALWAYS" styleClass="tabela-premium">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colColaboradorPendente" text="Colaborador" />
                        <TableColumn fx:id="colTipoPendente" text="Tipo" />
                        <TableColumn fx:id="colPeriodoPendente" text="Per&#237;odo" />
                        <TableColumn fx:id="colPrioridadePendente" text="Vig&#234;ncia" />
                        <TableColumn fx:id="colDescricaoPendente" text="Descri&#231;&#227;o" />
                    </columns>
                </TableView>

                <!-- Contexto do colaborador selecionado -->
                <VBox fx:id="painelContextoColaborador" managed="false" visible="false"
                      spacing="10.0" styleClass="pref-contexto-panel">
                    <Label fx:id="lblContextoNomeColaborador" styleClass="pref-contexto-nome" />
                    <Label styleClass="campo-titulo" text="Outras prefer&#234;ncias deste colaborador" />
                    <VBox fx:id="boxPreferenciasAtivas" spacing="6.0" />
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="campo-titulo" text="Observa&#231;&#227;o da decis&#227;o" />
                    <TextArea fx:id="txtDecisaoGestor" prefRowCount="3"
                              promptText="Opcional: acrescenta uma observa&#231;&#227;o para o hist&#243;rico da decis&#227;o."
                              wrapText="true" styleClass="campo-textarea" />
                </VBox>

                <Label fx:id="lblFeedbackGestao" managed="false" visible="false" wrapText="true" styleClass="mensagem-feedback" />

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button fx:id="btnRejeitarPreferencia" onAction="#onRejeitarPreferenciaClick"
                            styleClass="botao-secundario" text="Rejeitar" />
                    <Button fx:id="btnAprovarPreferencia" onAction="#onAprovarPreferenciaClick"
                            styleClass="botao-acao" text="Aprovar" />
                </HBox>

                <Label styleClass="card-titulo" text="Hist&#243;rico de decis&#245;es da loja" />
                <TableView fx:id="tabelaHistoricoDecisoes" VBox.vgrow="ALWAYS" styleClass="tabela-premium">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colColaboradorHistorico" text="Colaborador" />
                        <TableColumn fx:id="colEstadoHistorico" text="Estado" />
                        <TableColumn fx:id="colDecisaoHistorico" text="Observa&#231;&#227;o" />
                        <TableColumn fx:id="colDecisorHistorico" text="Decisor" />
                        <TableColumn fx:id="colDataDecisaoHistorico" text="Data da decis&#227;o" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
