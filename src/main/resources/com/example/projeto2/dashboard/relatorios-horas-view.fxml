<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="730.0" spacing="18.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projeto2.Controller.RelatoriosHorasController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <Label styleClass="titulo-dashboard" text="Relat&#243;rios mensais de horas" />
        <Label styleClass="subtitulo" text="Consulta o resumo mensal da equipa da tua loja e exporta os dados em CSV." />

        <VBox spacing="12.0" styleClass="info-card">
            <children>
                <Label styleClass="card-titulo" text="Filtros do relat&#243;rio" />
                <Label styleClass="meta-etiqueta" text="Loja" />
                <Label fx:id="lblLojaRelatorio" styleClass="meta-valor" text="-" />

                <HBox spacing="12.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="campo-titulo" text="M&#234;s" />
                                <ComboBox fx:id="cbMes" promptText="Seleciona o m&#234;s" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="campo-titulo" text="Ano" />
                                <Spinner fx:id="spAno" prefWidth="120.0" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="campo-titulo" text="Colaborador" />
                                <ComboBox fx:id="cbColaborador" promptText="Todos os colaboradores" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Button fx:id="btnGerarRelatorio" onAction="#onGerarRelatorioClick" styleClass="botao-acao" text="Gerar relat&#243;rio" />
                        <Button fx:id="btnExportarCsv" onAction="#onExportarCsvClick" styleClass="botao-secundario" text="Exportar CSV" />
                    </children>
                </HBox>

                <Label fx:id="lblFeedback" managed="false" visible="false" />
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblTotalColaboradores" styleClass="stat-numero" text="0" />
                        <Label styleClass="stat-titulo" text="Colaboradores" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblTotalTurnos" styleClass="stat-numero" text="0" />
                        <Label styleClass="stat-titulo" text="Turnos no m&#234;s" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblTotalHoras" styleClass="stat-numero" text="0h 0m" />
                        <Label styleClass="stat-titulo" text="Horas totais" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblTotalFolgas" styleClass="stat-numero" text="0" />
                        <Label styleClass="stat-titulo" text="Folgas aprovadas" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tabelaRelatorio" prefHeight="240.0" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colColaborador" prefWidth="220.0" text="Colaborador" />
                <TableColumn fx:id="colCargo" prefWidth="140.0" text="Cargo" />
                <TableColumn fx:id="colTurnos" prefWidth="120.0" text="Turnos" />
                <TableColumn fx:id="colFolgas" prefWidth="140.0" text="Folgas aprovadas" />
                <TableColumn fx:id="colHoras" prefWidth="140.0" text="Horas" />
            </columns>
        </TableView>
    </children>
</VBox>
