<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20.0"
      stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.projeto2.Controller.RelatoriosHorasController"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
    </padding>

    <!-- Cabeçalho -->
    <VBox spacing="4.0">
        <Label styleClass="titulo-dashboard" text="Relatórios mensais de horas" />
        <Label styleClass="subtitulo"
               text="Consulta o resumo mensal da equipa da tua loja e exporta os dados em CSV." />
    </VBox>

    <!-- Filtros -->
    <VBox spacing="14.0" styleClass="info-card">
        <Label styleClass="card-titulo" text="Filtros do relatório" />

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label styleClass="meta-etiqueta" text="Loja:" />
            <Label fx:id="lblLojaRelatorio" styleClass="meta-valor" text="-" />
        </HBox>

        <HBox spacing="14.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label styleClass="campo-titulo" text="Mês" />
                <ComboBox fx:id="cbMes" maxWidth="Infinity" promptText="Seleciona o mês" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="campo-titulo" text="Ano" />
                <Spinner fx:id="spAno" minWidth="110.0" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label styleClass="campo-titulo" text="Colaborador" />
                <ComboBox fx:id="cbColaborador" maxWidth="Infinity" promptText="Todos os colaboradores" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button fx:id="btnGerarRelatorio" onAction="#onGerarRelatorioClick"
                    styleClass="botao-acao" text="Gerar relatório" />
            <Button fx:id="btnExportarCsv" onAction="#onExportarCsvClick"
                    styleClass="botao-secundario" text="Exportar CSV" />
        </HBox>

        <Label fx:id="lblFeedback" managed="false" visible="false" wrapText="true" />
    </VBox>

    <!-- KPIs -->
    <HBox alignment="CENTER" spacing="14.0">
        <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalColaboradores" styleClass="stat-numero" text="0" />
            <Label styleClass="stat-titulo" text="Colaboradores" />
        </VBox>
        <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalTurnos" styleClass="stat-numero" text="0" />
            <Label styleClass="stat-titulo" text="Turnos no mês" />
        </VBox>
        <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalHoras" styleClass="stat-numero" text="0h 0m" />
            <Label styleClass="stat-titulo" text="Horas totais" />
        </VBox>
        <VBox alignment="CENTER" spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalFolgas" styleClass="stat-numero" text="0" />
            <Label styleClass="stat-titulo" text="Folgas aprovadas" />
        </VBox>
    </HBox>

    <!-- Tabela principal -->
    <VBox spacing="10.0" styleClass="info-card" VBox.vgrow="ALWAYS">
        <Label styleClass="card-titulo" text="Detalhe por colaborador" />
        <TableView fx:id="tabelaRelatorio" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colColaborador" text="Colaborador" />
                <TableColumn fx:id="colCargo" text="Cargo" />
                <TableColumn fx:id="colTurnos" text="Turnos" />
                <TableColumn fx:id="colFolgas" text="Folgas aprovadas" />
                <TableColumn fx:id="colHoras" text="Horas" />
            </columns>
        </TableView>
    </VBox>

</VBox>
